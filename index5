<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<title>AstraToonix v2 – Open World</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cannon.js/0.6.2/cannon.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:#000;font-family:'Rajdhani',sans-serif;touch-action:none;user-select:none;-webkit-user-select:none}
#game-canvas{position:fixed;inset:0;display:block;width:100%!important;height:100%!important}

/* ── LOADING ── */
#loading-screen{position:fixed;inset:0;z-index:10000;background:#06060f;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;transition:opacity .6s}
#loading-screen.out{opacity:0;pointer-events:none}
#loading-screen h1{font-family:'Orbitron',monospace;font-size:clamp(1.4rem,6vw,2.4rem);color:#7efff5;letter-spacing:6px;text-shadow:0 0 40px #7efff5;animation:glow 2s ease infinite;text-align:center}
#loading-screen small{font-family:'Orbitron',monospace;font-size:.58rem;color:#336;letter-spacing:3px}
@keyframes glow{0%,100%{text-shadow:0 0 40px #7efff5}50%{text-shadow:0 0 90px #7efff5,0 0 140px #7efff560}}
#lb-outer{width:min(280px,72vw);height:5px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden}
#lb-inner{height:100%;width:0%;background:linear-gradient(90deg,#7efff5,#64c8ff);border-radius:3px;transition:width .35s ease}
#loading-tip{font-family:'Rajdhani',sans-serif;font-size:.78rem;color:#445566;letter-spacing:2px}

/* ── PORTRAIT ── */
#portrait-ov{display:none;position:fixed;inset:0;z-index:9000;background:linear-gradient(135deg,#0d0d1f,#1a0a2e);flex-direction:column;align-items:center;justify-content:center;gap:18px}
#portrait-ov.show{display:flex}
#portrait-ov h2{font-family:'Orbitron',monospace;color:#7efff5;font-size:clamp(.9rem,5vw,1.3rem);text-align:center;letter-spacing:2px}
#portrait-ov p{color:#8899bb;font-size:.82rem}
#portrait-ov button{background:rgba(126,255,245,.1);border:2px solid #7efff5;color:#7efff5;font-family:'Orbitron',monospace;font-size:.62rem;letter-spacing:2px;padding:10px 22px;border-radius:6px;cursor:pointer}
.ri{font-size:60px;animation:rotA 1.8s ease-in-out infinite}
@keyframes rotA{0%,100%{transform:rotate(0)}40%,60%{transform:rotate(90deg)}}

/* ── LICENSE EXPIRED ── */
#license-ov{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.96);flex-direction:column;align-items:center;justify-content:center;gap:12px}
#license-ov.show{display:flex}
#license-ov h2{font-family:'Orbitron',monospace;color:#ff4455;font-size:clamp(1rem,4vw,1.4rem);letter-spacing:4px;text-shadow:0 0 24px #ff4455}
#license-ov p{color:#8899bb;font-size:.8rem;letter-spacing:1px}
#license-ov small{color:#ff4455;font-size:.6rem;letter-spacing:2px;margin-top:6px}

/* ── HUD TOP ── */
#hud{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:linear-gradient(180deg,rgba(0,0,0,.7) 0%,transparent 100%);pointer-events:none}
.hud-label{font-family:'Orbitron',monospace;font-size:.5rem;color:#7efff5;letter-spacing:2px}
.hpw{width:110px;height:7px;background:rgba(255,255,255,.1);border-radius:4px;overflow:hidden}
#hp-bar{height:100%;width:100%;background:linear-gradient(90deg,#00ff88,#7efff5);border-radius:4px;transition:width .3s}
#hud-title{font-family:'Orbitron',monospace;font-size:clamp(.48rem,2.2vw,.7rem);color:#fff;letter-spacing:3px;text-shadow:0 0 10px #7efff5}
#hud-zone{font-family:'Orbitron',monospace;font-size:.5rem;color:#ffcc44;letter-spacing:1px;text-align:right}

/* ── ZONE FLASH ── */
#zone-flash{position:fixed;top:50px;left:50%;transform:translateX(-50%);z-index:210;font-family:'Orbitron',monospace;font-size:clamp(.65rem,3vw,.95rem);color:#fff;letter-spacing:4px;text-shadow:0 0 20px #7efff5;opacity:0;transition:opacity .5s;pointer-events:none;white-space:nowrap}
#zone-flash.show{opacity:1}

/* ── TOAST ── */
#toast{position:fixed;top:60px;left:50%;transform:translateX(-50%);z-index:210;background:rgba(0,0,0,.84);border:1px solid #7efff530;border-radius:8px;padding:6px 16px;font-family:'Rajdhani',sans-serif;font-size:.8rem;color:#7efff5;letter-spacing:1px;opacity:0;pointer-events:none;transition:opacity .3s;white-space:nowrap;backdrop-filter:blur(8px)}
#toast.show{opacity:1}

/* ── VEHICLE HUD ── */
#vhud{position:fixed;bottom:128px;right:14px;z-index:210;display:none;flex-direction:column;align-items:flex-end;gap:3px}
#vhud.show{display:flex}
#spd{font-family:'Orbitron',monospace;font-size:clamp(1.2rem,6vw,1.9rem);color:#ffcc44;text-shadow:0 0 12px #ffcc4480}
#spd-u{font-size:.6rem;color:#8899bb;letter-spacing:2px;font-family:'Rajdhani',sans-serif}
#lights-btn{background:rgba(0,0,0,.6);border:1px solid #ffcc44;color:#ffcc44;font-family:'Orbitron',monospace;font-size:.46rem;letter-spacing:1px;padding:4px 10px;border-radius:4px;cursor:pointer;pointer-events:all;-webkit-tap-highlight-color:transparent}

/* ── ALTITUDE (heli) ── */
#alt-hud{position:fixed;bottom:128px;left:14px;z-index:210;display:none;flex-direction:column;align-items:flex-start;gap:2px}
#alt-hud.show{display:flex}
#alt-val{font-family:'Orbitron',monospace;font-size:1.1rem;color:#7efff5;text-shadow:0 0 10px #7efff580}
#alt-u{font-size:.55rem;color:#8899bb;letter-spacing:2px;font-family:'Rajdhani',sans-serif}

/* ── TRANSITION ── */
#fade-ov{position:fixed;inset:0;z-index:600;background:#000;opacity:0;pointer-events:none;transition:opacity .4s}
#fade-ov.on{opacity:1;pointer-events:all}

/* ── JOYSTICK ── */
#joy-zone{position:fixed;bottom:20px;left:20px;width:114px;height:114px;z-index:300;pointer-events:all}
#joy-base{width:114px;height:114px;border-radius:50%;background:rgba(126,255,245,.07);border:2px solid rgba(126,255,245,.22);position:relative}
#joy-thumb{width:44px;height:44px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#7efff5,#1a8888);border:2px solid rgba(255,255,255,.2);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);box-shadow:0 0 14px #7efff540}

/* ── ACTION BTNS ── */
#act-zone{position:fixed;bottom:20px;right:14px;z-index:300;pointer-events:all;display:flex;flex-direction:column;align-items:flex-end;gap:7px}
.ar{display:flex;gap:7px}
.abtn{width:46px;height:46px;border-radius:50%;border:2px solid rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:.46rem;color:#fff;cursor:pointer;backdrop-filter:blur(6px);-webkit-tap-highlight-color:transparent;transition:transform .1s}
.abtn:active{transform:scale(.87)}
#b-jump{background:rgba(126,255,245,.15);border-color:#7efff5}
#b-enter{background:rgba(255,204,68,.15);border-color:#ffcc44}
#b-attack{background:rgba(255,68,85,.15);border-color:#ff4455}
#b-down{background:rgba(180,100,255,.15);border-color:#b464ff}

/* ── NPC HUDS ── */
.npc-hud{position:fixed;z-index:220;pointer-events:none;display:flex;flex-direction:column;align-items:center;gap:2px}
.npc-name{font-family:'Rajdhani',sans-serif;font-size:.58rem;color:#fff;letter-spacing:1px;text-shadow:0 1px 4px #000}
.nbar-o{width:50px;height:5px;background:rgba(0,0,0,.5);border-radius:3px;overflow:hidden;border:1px solid rgba(255,255,255,.15)}
.nbar-i{height:100%;background:#ff4455;border-radius:3px;transition:width .3s}
.fear-i{font-size:.7rem;animation:fp .45s ease infinite alternate}
@keyframes fp{from{transform:scale(1)}to{transform:scale(1.35)}}

/* ── MINIMAP ── */
#minimap{position:fixed;top:46px;right:12px;z-index:210;width:80px;height:80px;border-radius:50%;overflow:hidden;pointer-events:none;border:1px solid rgba(126,255,245,.2)}
#mm-cv{width:80px;height:80px}

/* ── DEV CREDIT – SECURITY ANCHOR ── */
#dev-credit{position:fixed;bottom:5px;left:50%;transform:translateX(-50%);z-index:250;font-family:'Orbitron',monospace;font-size:.4rem;color:rgba(126,255,245,.28);letter-spacing:2px;pointer-events:none}
</style>
</head>
<body>

