}
function updateNPCs(dt) {
  npcs.forEach(n => {
    if (n.dead) return;
    if (n.fear) {
      n.fearT -= dt;
      if (n.fearT <= 0) { n.fear = false; const fi = n.hudEl.querySelector('.fear-i'); if (fi) fi.remove(); }
      n.g.position.x += n.fleeDir.x * 6 * dt;
      n.g.position.z += n.fleeDir.z * 6 * dt;
    } else {
      n.idleT -= dt;
      if (n.idleT <= 0) {
        n.walkDir.set(Math.random() * 2 - 1, 0, Math.random() * 2 - 1).normalize();
        n.idleT = 2 + Math.random() * 4;
      }
      n.g.position.x += n.walkDir.x * 1.4 * dt;
      n.g.position.z += n.walkDir.z * 1.4 * dt;
      n.g.rotation.y = Math.atan2(n.walkDir.x, n.walkDir.z);
    }
    n.g.position.x = Math.max(-2000, Math.min(2000, n.g.position.x));
    n.g.position.z = Math.max(-2000, Math.min(2000, n.g.position.z));
  });
}

// ── CAMERA (orbit-style, driven by touch-look) ───────────────
function updateCamera() {
  const tx = pBody.position.x, ty = pBody.position.y + 0.8, tz = pBody.position.z;
  const dist = S.vehicle === 'heli' ? 16 : (S.vehicle ? 10 : S.camDist);
  const pitch = Math.max(-0.1, Math.min(Math.PI / 2.2, S.camPitch));
  const cx = tx + Math.sin(S.camYaw) * Math.cos(pitch) * dist;
  const cy = ty + Math.sin(pitch) * dist;
  const cz = tz + Math.cos(S.camYaw) * Math.cos(pitch) * dist;
  camera.position.set(cx, Math.max(0.5, cy), cz);
  camera.lookAt(tx, ty, tz);
}

// ── PLAYER MOVEMENT (camera-relative) ────────────────────────
let footT = 0;
function updatePlayer(dt) {
  if (!S.alive || S.vehicle) return;
  let ix = S.joy.x, iy = -S.joy.y;
  if (S.keys.w) iy = -1; if (S.keys.s) iy = 1;
  if (S.keys.a) ix = -1; if (S.keys.d) ix = 1;

  // Camera-relative direction
  const fwd  = new THREE.Vector3(-Math.sin(S.camYaw), 0, -Math.cos(S.camYaw));
  const right = new THREE.Vector3(Math.cos(S.camYaw), 0, -Math.sin(S.camYaw));
  const move  = new THREE.Vector3();
  move.addScaledVector(fwd, -iy);
  move.addScaledVector(right, ix);
  if (move.lengthSq() > 0) move.normalize();

  const spd = 320;
  pBody.applyForce(new CANNON.Vec3(move.x * spd * dt, 0, move.z * spd * dt), pBody.position);
  pBody.angularVelocity.set(0, 0, 0);

  // Face direction of movement
  if (move.lengthSq() > 0.01) pYaw = Math.atan2(move.x, move.z);

  pMesh.position.set(pBody.position.x, pBody.position.y - 0.55, pBody.position.z);
  pMesh.rotation.y = pYaw;

  // Leg animation
  const moving = move.lengthSq() > 0.01;
  if (moving) {
    legPhase += dt * 8;
    legL.rotation.x =  Math.sin(legPhase) * 0.6;
    legR.rotation.x = -Math.sin(legPhase) * 0.6;
    footT -= dt;
    if (footT <= 0) {
      // Detect if on road (rough check by position modulo road grid)
      const onRoad = Math.abs(pBody.position.x % 80) < 8 || Math.abs(pBody.position.z % 80) < 8;
      SFX.foot(onRoad ? 'road' : 'grass');
      footT = 0.36;
    }
  } else {
    legL.rotation.x = legR.rotation.x = 0;
  }
}

// ── CAR CONTROL ──────────────────────────────────────────────
let carWheelRot = 0;
function updateCar(dt) {
  if (S.vehicle !== 'car') return;
  let ix = S.joy.x, iy = -S.joy.y;
  if (S.keys.w) iy = -1; if (S.keys.s) iy = 1;
  if (S.keys.a) ix = -1; if (S.keys.d) ix = 1;
  const ang = Math.atan2(carBody.quaternion.x, carBody.quaternion.w) * 2;
  carBody.applyForce(new CANNON.Vec3(-Math.sin(ang) * iy * 7000 * dt, 0, -Math.cos(ang) * iy * 7000 * dt), carBody.position);
  carBody.angularVelocity.y += ix * 0.06 * (iy >= 0 ? 1 : -1);
  carBody.angularVelocity.y *= 0.88;
  carBody.angularVelocity.x *= 0.4; carBody.angularVelocity.z *= 0.4;
  carBody.linearVelocity.y *= 0.96;
  carG.position.copy(carBody.position); carG.position.y -= 0.52;
  carG.quaternion.copy(carBody.quaternion);
  const spd = carBody.velocity.length();
  carWheelRot += spd * dt * 3.8;
  carWheels.forEach(w => { w.rotation.x = carWheelRot; });
  document.getElementById('spd').textContent = Math.round(spd * 3.6);
  SFX.revEngine(Math.min(spd / 18, 1));
  carG.position.y += Math.sin(Date.now() * 0.009) * 0.006 * spd;
  pBody.position.set(carBody.position.x, carBody.position.y + 1.2, carBody.position.z);
}

// ── BIKE CONTROL ─────────────────────────────────────────────
let bikeWheelRot = 0;
function updateBike(dt) {
  if (S.vehicle !== 'bike') return;
  let ix = S.joy.x, iy = -S.joy.y;
  if (S.keys.w) iy = -1; if (S.keys.s) iy = 1;
  if (S.keys.a) ix = -1; if (S.keys.d) ix = 1;
  const ang = Math.atan2(bikeBody.quaternion.x, bikeBody.quaternion.w) * 2;
  // Bike is faster, less stable
  bikeBody.applyForce(new CANNON.Vec3(-Math.sin(ang) * iy * 10000 * dt, 0, -Math.cos(ang) * iy * 10000 * dt), bikeBody.position);
  bikeBody.angularVelocity.y += ix * 0.09 * (iy >= 0 ? 1 : -1);
  bikeBody.angularVelocity.y *= 0.85;
  bikeBody.angularVelocity.x *= 0.5; bikeBody.angularVelocity.z *= 0.6;
  bikeBody.linearVelocity.y *= 0.97;
  bikeG.position.copy(bikeBody.position); bikeG.position.y -= 0.4;
  bikeG.quaternion.copy(bikeBody.quaternion);
  const spd = bikeBody.velocity.length();
  bikeWheelRot += spd * dt * 4.5;
  bikeWheels.forEach(w => { w.rotation.x = bikeWheelRot; });
  document.getElementById('spd').textContent = Math.round(spd * 3.6);
  SFX.revEngine(Math.min(spd / 22, 1));
  // Lean into turns
  bikeG.rotation.z = -ix * 0.18 * Math.min(spd / 8, 1);
  pBody.position.set(bikeBody.position.x, bikeBody.position.y + 0.9, bikeBody.position.z);
}

// ── HELICOPTER CONTROL ───────────────────────────────────────
let heliLifting = false, heliDescending = false;

function updateHeli(dt) {
  if (S.vehicle !== 'heli') return;
  let ix = S.joy.x, iy = -S.joy.y;
  if (S.keys.a) ix = -1; if (S.keys.d) ix = 1;
  if (S.keys.w) iy = -1; if (S.keys.s) iy = 1;

  // Thrust relative to helicopter's up axis
  const liftForce = heliLifting ? 28000 * dt : 0;
  const downForce = heliDescending ? -16000 * dt : 0;
  const gravity = 22 * 1200 * dt;  // counteract gravity when flying
  heliBody.applyForce(new CANNON.Vec3(0, liftForce + downForce + (S.vehicle === 'heli' ? gravity * 0.92 : 0), 0), heliBody.position);

  // Tilt to move horizontally
  const horizForce = 5000;
  const hAngle = Math.atan2(heliBody.quaternion.x, heliBody.quaternion.w) * 2;
  heliBody.applyForce(new CANNON.Vec3(
    -Math.sin(hAngle) * iy * horizForce * dt + ix * horizForce * dt,
    0,
    -Math.cos(hAngle) * iy * horizForce * dt
  ), heliBody.position);

  // Yaw from joystick x
  heliBody.angularVelocity.y += ix * 0.04;
  heliBody.angularVelocity.y *= 0.9;
  heliBody.angularVelocity.x *= 0.6;
  heliBody.angularVelocity.z *= 0.6;

  // Keep mostly upright
  const tilt = ix * 0.18;
  heliG.rotation.z += (-tilt - heliG.rotation.z) * 0.1;
  heliG.rotation.x += (-iy * 0.15 - heliG.rotation.x) * 0.1;

  heliG.position.copy(heliBody.position);
  heliG.position.y -= 0.65;
  heliG.quaternion.copy(heliBody.quaternion);

  // Spin rotors
  rotorAngle += dt * (heliLifting ? 25 : 15);
  rotorMesh.rotation.y = rotorAngle;
  tailRotorMesh.rotation.x = rotorAngle * 3;

  const alt = Math.max(0, heliBody.position.y - 2);
  document.getElementById('alt-val').textContent = Math.round(alt);
  const spd = heliBody.velocity.length();
  SFX.revRotors(Math.min(spd / 15, 1));

  pBody.position.set(heliBody.position.x, heliBody.position.y + 0.8, heliBody.position.z);
}

// ── DOOR ANIMATION ───────────────────────────────────────────
function updateDoors(dt) {
  buildings.forEach(b => {
    if (b.doorOpening && b.doorAngle < Math.PI / 2) {
      b.doorAngle = Math.min(b.doorAngle + dt * 2.8, Math.PI / 2);
      b.doorPivot.rotation.y = b.doorAngle;
    }
  });
}

// ── PROXIMITY: find nearest vehicle ──────────────────────────
function findNearestVehicle() {
  const pp = new THREE.Vector3(pBody.position.x, pBody.position.y, pBody.position.z);
  const dCar = carG ? pp.distanceTo(new THREE.Vector3(carBody.position.x, carBody.position.y, carBody.position.z)) : 9999;
  const dBike = bikeG ? pp.distanceTo(new THREE.Vector3(bikeBody.position.x, bikeBody.position.y, bikeBody.position.z)) : 9999;
  const dHeli = heliG ? pp.distanceTo(new THREE.Vector3(heliBody.position.x, heliBody.position.y, heliBody.position.z)) : 9999;
  const minD = Math.min(dCar, dBike, dHeli);
  if (minD > 5) return null;
  if (minD === dCar) return 'car';
  if (minD === dBike) return 'bike';
  return 'heli';
}

function findNearestBuilding() {
  const pp = new THREE.Vector3(pBody.position.x, pBody.position.y, pBody.position.z);
  let nearest = null, minD = 8;
  buildings.forEach((b, i) => {
    const d = pp.distanceTo(b.worldPos);
    if (d < minD) { minD = d; nearest = { b, i }; }
  });
  return nearest;
}

// ── ENTER / EXIT ──────────────────────────────────────────────
function onEnterExit() {
  if (!S.alive) return;

  if (S.vehicle) {
    // EXIT
    const exitVeh = S.vehicle;
    S.vehicle = null;
    pMesh.visible = true;
    document.getElementById('vhud').classList.remove('show');
    document.getElementById('alt-hud').classList.remove('show');
    if (exitVeh === 'car') { SFX.stopEngine(); pBody.position.set(carBody.position.x + 3, carBody.position.y, carBody.position.z); }
    if (exitVeh === 'bike') { SFX.stopEngine(); pBody.position.set(bikeBody.position.x + 2, bikeBody.position.y, bikeBody.position.z); }
    if (exitVeh === 'heli') { SFX.stopRotors(); pBody.position.set(heliBody.position.x + 3, heliBody.position.y, heliBody.position.z); }
    pBody.velocity.set(0, 0, 0);
    flashZone('Open World');
    toast('Exited ' + exitVeh);
    return;
  }

  if (S.inside) {
    // EXIT building
    const b = buildings[S.insideBldIdx];
    fadeIn(() => {
      if (b) {
        pBody.position.set(b.exitPos.x, b.exitPos.y, b.exitPos.z);
        pBody.velocity.set(0, 0, 0);
        if (b.interior) { b.interior.visible = false; }
        b.group.visible = true;
      }
      S.inside = false; S.insideBldIdx = -1;
      flashZone('Open World');
    });
    SFX.door();
    return;
  }

  // Check buildings first (door raycaster)
  const nb = findNearestBuilding();
  if (nb) {
    const b = nb.b;
    SFX.door();
    if (!b.doorOpen) { b.doorOpening = true; b.doorOpen = true; }
    // Seamless transition into building
    fadeIn(() => {
      pBody.position.set(b.worldPos.x, 1, b.worldPos.z);
      pBody.velocity.set(0, 0, 0);
      S.inside = true; S.insideBldIdx = nb.i;
      b.group.visible = false;
      flashZone('Inside: ' + b.label);
      toast('Press ENTER to exit');
    });
    return;
  }

  // Try vehicles
  const veh = findNearestVehicle();
  if (veh) {
    S.vehicle = veh;
    pMesh.visible = false;
    document.getElementById('vhud').classList.toggle('show', veh !== 'heli');
    document.getElementById('alt-hud').classList.toggle('show', veh === 'heli');
    if (veh === 'heli') { SFX.startRotors(); flashZone('Helicopter'); toast('UP=rise  DOWN=descend  Joystick=move'); }
    else { SFX.startEngine(); flashZone(veh === 'car' ? 'Sports Car' : 'Motorcycle'); toast('Joystick to drive • ENTER to exit'); }
    return;
  }

  toast('Nothing nearby to enter.');
}

// ── JUMP / UP / DOWN ─────────────────────────────────────────
function onUp() {
  if (!S.alive) return;
  if (S.vehicle === 'heli') { heliLifting = true; return; }
  if (!S.vehicle && pBody.position.y < 2.8) { pBody.velocity.y = 10; SFX.jump(); }
}
function onUpEnd() { heliLifting = false; }
function onDown() { if (S.vehicle === 'heli') heliDescending = true; }
function onDownEnd() { heliDescending = false; }

function onAttack() {
  if (!S.alive || S.vehicle) return;
  SFX.hit(); damageNearNPC();
}

function toggleLights() {
  if (!S.vehicle || S.vehicle === 'heli') return;
  S.lights = !S.lights;
  if (carG.__lights) carG.__lights.forEach(l => l.intensity = S.lights ? 3.5 : 0);
  toast(S.lights ? '💡 Headlights ON' : '💡 Headlights OFF');
}
window.toggleLights = toggleLights;

// ── BUTTON WIRING ─────────────────────────────────────────────
function wire(id, downFn, upFn) {
  const el = document.getElementById(id);
  if (!el) return;
  el.addEventListener('touchstart', e => { e.preventDefault(); downFn && downFn(); }, { passive: false });
  el.addEventListener('touchend',   e => { e.preventDefault(); upFn   && upFn();   }, { passive: false });
  el.addEventListener('mousedown', () => downFn && downFn());
  el.addEventListener('mouseup',   () => upFn   && upFn());
}
wire('b-jump',   onUp,   onUpEnd);
wire('b-down',   onDown, onDownEnd);
wire('b-enter',  onEnterExit, null);
wire('b-attack', onAttack, null);
wire('lights-btn', toggleLights, null);

// ── KEYBOARD ──────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'w' || e.key === 'ArrowUp')    S.keys.w = true;
  if (e.key === 's' || e.key === 'ArrowDown')  S.keys.s = true;
  if (e.key === 'a' || e.key === 'ArrowLeft')  S.keys.a = true;
  if (e.key === 'd' || e.key === 'ArrowRight') S.keys.d = true;
  if (e.key === ' ')  { e.preventDefault(); onUp(); }
  if (e.key === 'c')  onDown();
  if (e.key === 'e' || e.key === 'E') onEnterExit();
  if (e.key === 'f' || e.key === 'F') onAttack();
  if (e.key === 'h' || e.key === 'H') toggleLights();
});
document.addEventListener('keyup', e => {
  if (e.key === 'w' || e.key === 'ArrowUp')    S.keys.w = false;
  if (e.key === 's' || e.key === 'ArrowDown')  S.keys.s = false;
  if (e.key === 'a' || e.key === 'ArrowLeft')  S.keys.a = false;
  if (e.key === 'd' || e.key === 'ArrowRight') S.keys.d = false;
  if (e.key === ' ')  onUpEnd();
  if (e.key === 'c')  onDownEnd();
});

// ── TOUCH JOYSTICK (LEFT 30%) ─────────────────────────────────
const jBase  = document.getElementById('joy-base');
const jThumb = document.getElementById('joy-thumb');
let jTid = null;
const JR = 35;

jBase.addEventListener('touchstart', e => {
  e.preventDefault();
  jTid = e.changedTouches[0].identifier;
}, { passive: false });

document.addEventListener('touchmove', e => {
  if (jTid === null) return;
  const t = [...e.changedTouches].find(t => t.identifier === jTid);
  if (!t) return;
  e.preventDefault();
  const r = jBase.getBoundingClientRect();
  let dx = t.clientX - (r.left + r.width / 2);
  let dy = t.clientY - (r.top  + r.height / 2);
  const dist = Math.sqrt(dx * dx + dy * dy);
  if (dist > JR) { dx = dx / dist * JR; dy = dy / dist * JR; }
  jThumb.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
  S.joy.x = dx / JR; S.joy.y = dy / JR;
}, { passive: false });

function resetJoy() {
  jThumb.style.transform = 'translate(-50%,-50%)';
  S.joy.x = S.joy.y = 0; jTid = null;
}
document.addEventListener('touchend', e => {
  if ([...e.changedTouches].find(t => t.identifier === jTid)) resetJoy();
});

// ── TOUCH-TO-LOOK (RIGHT 70% of screen) ──────────────────────
// Swipe on right 70% of screen rotates camera (orbit style)
let lookTid = null, lookLastX = 0, lookLastY = 0;

document.addEventListener('touchstart', e => {
  for (let i = 0; i < e.changedTouches.length; i++) {
    const t = e.changedTouches[i];
    if (t.clientX > innerWidth * 0.30 && t.identifier !== jTid) {
      // Not a joystick touch, not on UI buttons
      const el = document.elementFromPoint(t.clientX, t.clientY);
      if (el && (el.classList.contains('abtn') || el.id === 'lights-btn')) continue;
      lookTid   = t.identifier;
      lookLastX = t.clientX;
      lookLastY = t.clientY;
    }
  }
}, { passive: true });

document.addEventListener('touchmove', e => {
  if (lookTid === null) return;
  const t = [...e.changedTouches].find(t => t.identifier === lookTid);
  if (!t) return;
  const dx = t.clientX - lookLastX;
  const dy = t.clientY - lookLastY;
  S.camYaw   += dx * 0.004;
  S.camPitch += dy * 0.004;
  S.camPitch = Math.max(-0.05, Math.min(Math.PI / 2.1, S.camPitch));
  lookLastX = t.clientX;
  lookLastY = t.clientY;
}, { passive: true });

document.addEventListener('touchend', e => {
  if ([...e.changedTouches].find(t => t.identifier === lookTid)) {
    lookTid = null;
  }
});

// Mouse drag look (desktop)
let mouseLook = false, mouseLX = 0, mouseLY = 0;
document.addEventListener('mousedown', e => {
  if (e.button === 2 || (e.clientX > innerWidth * 0.3 && !e.target.closest('.abtn') && e.target.id !== 'lights-btn')) {
    mouseLook = true; mouseLX = e.clientX; mouseLY = e.clientY;
  }
});
document.addEventListener('mousemove', e => {
  if (!mouseLook) return;
  S.camYaw   += (e.clientX - mouseLX) * 0.004;
  S.camPitch += (e.clientY - mouseLY) * 0.004;
  S.camPitch = Math.max(-0.05, Math.min(Math.PI / 2.1, S.camPitch));
  mouseLX = e.clientX; mouseLY = e.clientY;
});
document.addEventListener('mouseup', () => { mouseLook = false; });
document.addEventListener('contextmenu', e => e.preventDefault());

// ── MINIMAP ───────────────────────────────────────────────────
const mmCtx = document.getElementById('mm-cv').getContext('2d');
const MMS = 80 / 600; // 600 world units → 80px

function drawMinimap() {
  mmCtx.clearRect(0, 0, 80, 80);
  mmCtx.fillStyle = 'rgba(12,18,32,.78)';
  mmCtx.beginPath(); mmCtx.arc(40, 40, 40, 0, Math.PI * 2); mmCtx.fill();
  // Roads
  mmCtx.strokeStyle = '#333344'; mmCtx.lineWidth = 1.5;
  for (let i = -4; i <= 4; i++) {
    mmCtx.beginPath(); mmCtx.moveTo(40 + i * 80 * MMS, 0); mmCtx.lineTo(40 + i * 80 * MMS, 80); mmCtx.stroke();
    mmCtx.beginPath(); mmCtx.moveTo(0, 40 + i * 80 * MMS); mmCtx.lineTo(80, 40 + i * 80 * MMS); mmCtx.stroke();
  }
  // Vehicles
  [[carBody, '#ff4444', 3], [bikeBody, '#4466ff', 2.5], [heliBody, '#44ff88', 2.5]].forEach(([b, col, r]) => {
    if (!b) return;
    mmCtx.fillStyle = col;
    mmCtx.beginPath(); mmCtx.arc(40 + b.position.x * MMS, 40 + b.position.z * MMS, r, 0, Math.PI * 2); mmCtx.fill();
  });
  // NPCs
  mmCtx.fillStyle = '#ffcc44';
  npcs.forEach(n => {
    if (n.dead) return;
    const nx = 40 + n.g.position.x * MMS, nz = 40 + n.g.position.z * MMS;
    mmCtx.beginPath(); mmCtx.arc(nx, nz, 1.2, 0, Math.PI * 2); mmCtx.fill();
  });
  // Player
  if (pBody) {
    const px = 40 + pBody.position.x * MMS, pz = 40 + pBody.position.z * MMS;
    mmCtx.fillStyle = '#ffffff';
    mmCtx.beginPath(); mmCtx.arc(px, pz, 3, 0, Math.PI * 2); mmCtx.fill();
    mmCtx.strokeStyle = '#7efff5'; mmCtx.lineWidth = 1.5;
    mmCtx.beginPath(); mmCtx.moveTo(px, pz);
    mmCtx.lineTo(px - Math.sin(S.camYaw) * 8, pz - Math.cos(S.camYaw) * 8); mmCtx.stroke();
  }
  // Clip
  mmCtx.globalCompositeOperation = 'destination-in';
  mmCtx.beginPath(); mmCtx.arc(40, 40, 40, 0, Math.PI * 2); mmCtx.fill();
  mmCtx.globalCompositeOperation = 'source-over';
}

// ── PROXIMITY TOAST HINTS ─────────────────────────────────────
let hintTimer = 0;
function updateHints(dt) {
  hintTimer -= dt;
  if (hintTimer > 0) return;
  hintTimer = 2;
  const veh = findNearestVehicle();
  if (veh && !S.vehicle) toast('Press ENTER to get in ' + veh, 1800);
}

// ── MAIN LOOP ─────────────────────────────────────────────────
const FIXED = 1 / 60; let lastT = null;

function loop(t) {
  requestAnimationFrame(loop);
  const dt = lastT === null ? FIXED : Math.min((t - lastT) / 1000, 0.05);
  lastT = t;

  if (!S.alive) { renderer.render(scene, camera); return; }

  world.step(FIXED, dt, 3);
  updatePlayer(dt);
  updateCar(dt);
  updateBike(dt);
  updateHeli(dt);
  updateDoors(dt);
  updateNPCs(dt);
  updateNPCHUDs();
  updateCamera();
  updateHints(dt);
  document.getElementById('hp-bar').style.width = S.hp + '%';
  drawMinimap();
  renderer.render(scene, camera);
}

// ── INIT ──────────────────────────────────────────────────────
async function init() {
  setLoad(5, 'Security check…');
  await sleep(120);

  // ── SECURITY: Raj Dev license check ──
  if (!checkLicense()) {
    setLoad(100, 'License check failed.');
    setTimeout(() => document.getElementById('loading-screen').classList.add('out'), 1000);
    return;
  }

  setLoad(15, 'Building 5000m world…');
  await sleep(160);
  buildRoads();

  setLoad(30, 'Generating procedural city (220 buildings)…');
  await sleep(200);
  buildProceduralCity();

  setLoad(52, 'Placing street props…');
  await sleep(160);
  buildStreetProps();

  setLoad(62, 'Spawning vehicles…');
  await sleep(120);
  buildCar(12, 0);
  buildBike(-12, 0);
  buildHeli(0, 60);

  setLoad(74, 'Placing player…');
  await sleep(100);
  buildPlayer();

  setLoad(84, 'Spawning NPCs…');
  await sleep(120);
  buildNPCs(18);

  setLoad(94, 'Starting city ambience…');
  await sleep(100);
  SFX.startCity();

  setLoad(100, 'Welcome to AstraToonix v2!');
  await sleep(400);

  S.alive = true;
  const ls = document.getElementById('loading-screen');
  ls.classList.add('out');
  setTimeout(() => ls.style.display = 'none', 700);

  flashZone('Open World');
  setTimeout(() => toast('Swipe RIGHT side = look | Joystick = move | ENTER = vehicle/building'), 1000);
  setTimeout(() => toast('Car=red • Bike=blue • Helicopter=green (ahead 60m)'), 4000);

  requestAnimationFrame(loop);
}

init();
</script>
