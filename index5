function damageNearNPC() {
  const pp = new THREE.Vector3(pBody.position.x, pBody.position.y, pBody.position.z);
  let nearest = null, minD = 5;
  npcs.forEach(n => {
    if (n.dead) return;
    const d = n.g.position.distanceTo(pp);
    if (d < minD) { minD = d; nearest = n; }
  });
  if (!nearest) { toast('No one nearby!'); return; }
  nearest.hp -= 25;
  nearest.fear = true; nearest.fearT = 6;
  nearest.fleeDir.set(nearest.g.position.x - pp.x, 0, nearest.g.position.z - pp.z).normalize();
  SFX.scream(); SFX.hit();
  nearest.barEl.style.width = Math.max(0, nearest.hp) + '%';
  if (nearest.hp <= 0) {
    nearest.dead = true; nearest.g.visible = false; nearest.hudEl.style.display = 'none';
    toast(nearest.name + ' is down!');
  } else {
    if (!nearest.hudEl.querySelector('.fear-i')) {
      const fi = document.createElement('div'); fi.className = 'fear-i'; fi.textContent = '😱';
      nearest.hudEl.prepend(fi);
    }
    toast(nearest.name + ': ' + nearest.hp + 'HP — RUNNING!');
  }
}

const projV = new THREE.Vector3();
function updateNPCHUDs() {
  npcs.forEach(n => {
    if (n.dead) return;
    projV.set(n.g.position.x, n.g.position.y + 1.5, n.g.position.z);
    projV.project(camera);
    const sx = (projV.x + 1) * innerWidth * 0.5;
    const sy = (-projV.y + 1) * innerHeight * 0.5;
    if (projV.z < 1 && sx > 0 && sx < innerWidth && sy > 0 && sy < innerHeight) {
      n.hudEl.style.cssText = `display:flex;left:${sx}px;top:${sy}px;transform:translate(-50%,-100%)`;
    } else { n.hudEl.style.display = 'none'; }
