  ================================================================
-->
<div id="dev-credit">Raj Dev</div>

<script>
'use strict';
/* ================================================================
   ASTRATOONIX OPEN WORLD ENGINE  v2.0
   Author  : Raj Dev
   Security: const DEV = "Raj Dev" + DOM credit check
   Features: Procedural city, Car, Bike, Helicopter, Touch-Look
================================================================ */

// ── SECURITY CONSTANT ─────────────────────────────────────────
const DEV = "Raj Dev";   // Hard-coded — DO NOT REMOVE

function checkLicense() {
  const el = document.getElementById('dev-credit');
  if (!el || el.textContent.trim() !== DEV) {
    document.getElementById('license-ov').classList.add('show');
    return false;
  }
  return true;
}

// ── PORTRAIT ─────────────────────────────────────────────────
let portraitOk = false;
document.getElementById('portrait-ok').addEventListener('click', () => {
  portraitOk = true; document.getElementById('portrait-ov').classList.remove('show');
});
function chkOrient() {
  if (portraitOk) return;
  document.getElementById('portrait-ov').classList
    .toggle('show', window.innerHeight > window.innerWidth + 60);
}
window.addEventListener('resize', chkOrient);
window.addEventListener('orientationchange', () => setTimeout(chkOrient, 300));
setTimeout(chkOrient, 900);

// ── LOADING ──────────────────────────────────────────────────
function setLoad(p, t) {
  document.getElementById('lb-inner').style.width = p + '%';
  if (t) document.getElementById('loading-tip').textContent = t;
}
const sleep = ms => new Promise(r => setTimeout(r, ms));

// ── SOUND MANAGER ────────────────────────────────────────────
const SFX = (() => {
  let AC = null, rotorOsc = null, rotorGain = null, rotorOn = false;
  let engOsc = null, engGain = null, engOn = false;
  let cityOsc = null, cityGain = null;

  function ctx() {
    if (!AC) AC = new (window.AudioContext || window.webkitAudioContext)();
    if (AC.state === 'suspended') AC.resume().catch(() => {});
    return AC;
  }
  function beep(f, d, type = 'sine', v = 0.08) {
    try {
      const c = ctx(), o = c.createOscillator(), g = c.createGain();
      o.type = type; o.frequency.setValueAtTime(f, c.currentTime);
      g.gain.setValueAtTime(v, c.currentTime);
      g.gain.exponentialRampToValueAtTime(0.0001, c.currentTime + d);
      o.connect(g); g.connect(c.destination); o.start(); o.stop(c.currentTime + d);
    } catch (e) {}
  }

  return {
    foot(s) {
      if (s === 'road') beep(120 + Math.random() * 40, 0.07, 'triangle', 0.03);
      else beep(150 + Math.random() * 40, 0.08, 'triangle', 0.035);
    },
    startEngine() {
      if (engOn) return;
      try {
        const c = ctx(); engOsc = c.createOscillator(); engGain = c.createGain();
        engOsc.type = 'sawtooth'; engOsc.frequency.setValueAtTime(55, c.currentTime);
        engGain.gain.setValueAtTime(0.06, c.currentTime);
        engOsc.connect(engGain); engGain.connect(c.destination); engOsc.start(); engOn = true;
      } catch (e) {}
    },
    stopEngine() {
      if (!engOn) return;
      try { engGain.gain.exponentialRampToValueAtTime(0.0001, ctx().currentTime + 0.4); engOsc.stop(ctx().currentTime + 0.5); } catch (e) {}
      engOn = false; engOsc = null; engGain = null;
    },
    revEngine(t) {
      if (!engOsc || !engOn) return;
      try { engOsc.frequency.setValueAtTime(55 + t * 220, ctx().currentTime); } catch (e) {}
    },
    startRotors() {
      if (rotorOn) return;
      try {
        const c = ctx(); rotorOsc = c.createOscillator(); rotorGain = c.createGain();
        rotorOsc.type = 'square'; rotorOsc.frequency.setValueAtTime(28, c.currentTime);
        rotorGain.gain.setValueAtTime(0.09, c.currentTime);
        rotorOsc.connect(rotorGain); rotorGain.connect(c.destination); rotorOsc.start(); rotorOn = true;
      } catch (e) {}
    },
    stopRotors() {
      if (!rotorOn) return;
      try { rotorGain.gain.exponentialRampToValueAtTime(0.0001, ctx().currentTime + 1); rotorOsc.stop(ctx().currentTime + 1.2); } catch (e) {}
      rotorOn = false;
    },
    revRotors(t) {
      if (!rotorOsc || !rotorOn) return;
      try { rotorOsc.frequency.setValueAtTime(28 + t * 60, ctx().currentTime); } catch (e) {}
    },
    startCity() {
      try {
        const c = ctx(); cityOsc = c.createOscillator(); cityGain = c.createGain();
        cityOsc.type = 'sine'; cityOsc.frequency.setValueAtTime(80, c.currentTime);
        cityGain.gain.setValueAtTime(0.025, c.currentTime);
        cityOsc.connect(cityGain); cityGain.connect(c.destination); cityOsc.start();
      } catch (e) {}
    },
    hit()    { beep(90, 0.08, 'square', 0.1); },
    jump()   { beep(260, 0.1, 'sine', 0.06); },
    door()   { beep(200, 0.12, 'triangle', 0.07); },
    scream() { beep(850, 0.22, 'sawtooth', 0.09); setTimeout(() => beep(620, 0.18, 'sawtooth', 0.06), 110); },
    horn()   { beep(440, 0.3, 'square', 0.14); }
  };
})();

// ── UI HELPERS ───────────────────────────────────────────────
let toastTmr = null;
function toast(msg, dur = 2800) {
  const el = document.getElementById('toast');
  el.textContent = msg; el.classList.add('show');
  clearTimeout(toastTmr);
  toastTmr = setTimeout(() => el.classList.remove('show'), dur);
}
let zoneTmr = null;
function flashZone(name) {
  const el = document.getElementById('zone-flash');
  el.textContent = name; el.classList.add('show');
  document.getElementById('hud-zone').textContent = name;
  clearTimeout(zoneTmr);
  zoneTmr = setTimeout(() => el.classList.remove('show'), 3000);
}
function fadeIn(cb) {
  const ov = document.getElementById('fade-ov');
  ov.classList.add('on');
  setTimeout(() => { cb(); ov.classList.remove('on'); }, 440);
}

// ── THREE + CANNON SETUP ─────────────────────────────────────
const canvas = document.getElementById('game-canvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, powerPreference: 'high-performance' });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;

const scene = new THREE.Scene();
scene.fog = new THREE.Fog(0x87ceeb, 80, 600);

const camera = new THREE.PerspectiveCamera(65, innerWidth / innerHeight, 0.1, 800);

const world = new CANNON.World();
world.gravity.set(0, -22, 0);
world.broadphase = new CANNON.SAPBroadphase(world);
world.solver.iterations = 10;

function onResize() {
  renderer.setSize(innerWidth, innerHeight, false);
  camera.aspect = innerWidth / innerHeight;
  camera.updateProjectionMatrix();
}
window.addEventListener('resize', onResize);
onResize();

// ── GAME STATE ───────────────────────────────────────────────
const S = {
  alive: false,
  vehicle: null,       // null | 'car' | 'bike' | 'heli'
  inside: false,
  insideBldIdx: -1,
  hp: 100,
  lights: false,
  keys: { w: false, a: false, s: false, d: false },
  joy: { x: 0, y: 0 },
  // Camera spherical angles
  camYaw: 0,
  camPitch: 0.35,
  camDist: 8
};

// ── LIGHTING ─────────────────────────────────────────────────
scene.add(new THREE.AmbientLight(0xffffff, 0.55));
const sun = new THREE.DirectionalLight(0xfff5e0, 1.1);
sun.position.set(200, 300, 100);
sun.castShadow = true;
sun.shadow.mapSize.set(1024, 1024);
sun.shadow.camera.near = 1; sun.shadow.camera.far = 800;
[-200, 200].forEach(v => {
  sun.shadow.camera.left = -200; sun.shadow.camera.right = 200;
  sun.shadow.camera.bottom = -200; sun.shadow.camera.top = 200;
});
scene.add(sun);

// Sky
const skyG = new THREE.SphereGeometry(750, 16, 16); skyG.scale(-1, 1, 1);
const skyC = [], skyP = skyG.attributes.position;
for (let i = 0; i < skyP.count; i++) {
  const t = (skyP.getY(i) / 750 + 1) / 2;
  skyC.push(0.5 - t * 0.25, 0.76 - t * 0.3, 0.92 - t * 0.22);
}
skyG.setAttribute('color', new THREE.Float32BufferAttribute(skyC, 3));
scene.add(new THREE.Mesh(skyG, new THREE.MeshBasicMaterial({ vertexColors: true, side: THREE.BackSide })));

// ── GROUND (5000×5000) ───────────────────────────────────────
const groundMesh = new THREE.Mesh(
  new THREE.PlaneGeometry(5000, 5000),
  new THREE.MeshLambertMaterial({ color: 0x3a7a30 })
);
groundMesh.rotation.x = -Math.PI / 2; groundMesh.receiveShadow = true;
scene.add(groundMesh);

const groundBody = new CANNON.Body({ mass: 0 });
groundBody.addShape(new CANNON.Plane());
groundBody.quaternion.setFromAxisAngle(new CANNON.Vec3(1, 0, 0), -Math.PI / 2);
world.addBody(groundBody);

// ── ROAD NETWORK (grid) ──────────────────────────────────────
const roadMat = new THREE.MeshLambertMaterial({ color: 0x222233 });
const markMat = new THREE.MeshBasicMaterial({ color: 0xffee44 });
function buildRoads() {
  const step = 80, count = 30, half = step * count / 2;
  const roadW = 14, len = step * count;
  for (let i = -count / 2; i <= count / 2; i++) {
    // N-S road
    const rm1 = new THREE.Mesh(new THREE.PlaneGeometry(roadW, len), roadMat);
    rm1.rotation.x = -Math.PI / 2; rm1.position.set(i * step, 0.015, 0);
    scene.add(rm1);
    // E-W road
    const rm2 = new THREE.Mesh(new THREE.PlaneGeometry(len, roadW), roadMat);
    rm2.rotation.x = -Math.PI / 2; rm2.position.set(0, 0.015, i * step);
    scene.add(rm2);
  }
  // Center line markings (dashed — sampled)
  for (let i = -count / 2; i <= count / 2; i++) {
    for (let j = -8; j <= 8; j++) {
      const mk = new THREE.Mesh(new THREE.PlaneGeometry(0.35, 6), markMat);
      mk.rotation.x = -Math.PI / 2;
      mk.position.set(i * step, 0.02, j * 10);
      scene.add(mk);
      const mk2 = new THREE.Mesh(new THREE.PlaneGeometry(6, 0.35), markMat);
      mk2.rotation.x = -Math.PI / 2;
      mk2.position.set(j * 10, 0.02, i * step);
      scene.add(mk2);
    }
  }
}

// ── PROCEDURAL BUILDINGS (200+, InstancedMesh) ───────────────
const buildings = []; // { pos, halfH, doorOpen, doorMesh }
const BLDG_COUNT = 220;

function buildProceduralCity() {
  // Use separate colored groups but batch per color bucket for perf
  const bldgColors = [0xc8b090, 0x9ab0c8, 0xc89090, 0x90c8a0, 0xd4c080, 0xa090c8, 0xc0c0c0, 0xd08060];
  const roofColors = [0x8b3a3a, 0x3a5a8b, 0x6a3a8b, 0x3a8b6a, 0x8b7a3a];

  const rng = (() => { let s = 42; return () => { s = (s * 1664525 + 1013904223) & 0xffffffff; return (s >>> 0) / 0xffffffff; }; })();

  for (let i = 0; i < BLDG_COUNT; i++) {
    // Place in city grid but not on roads
    let bx, bz;
    const block = 80;
    do {
      const gx = Math.floor(rng() * 30) - 15;
      const gz = Math.floor(rng() * 30) - 15;
      bx = gx * block + (rng() - 0.5) * 50;
      bz = gz * block + (rng() - 0.5) * 50;
    } while (Math.abs(bx % block) < 10 || Math.abs(bz % block) < 10);

    const bw = 8 + rng() * 14;
    const bd = 8 + rng() * 14;
    const bh = 6 + rng() * rng() * 80;   // random height (tall skyscrapers too)
    const col = bldgColors[Math.floor(rng() * bldgColors.length)];
    const rCol = roofColors[Math.floor(rng() * roofColors.length)];

    const group = new THREE.Group();

    // Main body
    const bodyMesh = new THREE.Mesh(
      new THREE.BoxGeometry(bw, bh, bd),
      new THREE.MeshLambertMaterial({ color: col })
    );
    bodyMesh.position.y = bh / 2;
    bodyMesh.castShadow = true; bodyMesh.receiveShadow = true;
    group.add(bodyMesh);

    // Roof
    const roofH = bw * 0.25;
    const roofMesh = new THREE.Mesh(
      new THREE.BoxGeometry(bw + 0.4, 0.6, bd + 0.4),
      new THREE.MeshLambertMaterial({ color: rCol })
    );
    roofMesh.position.y = bh + 0.3; group.add(roofMesh);

    // Windows (rows of small planes — skip for tall buildings for perf)
    if (bh < 30) {
      const winMat = new THREE.MeshLambertMaterial({ color: 0x88ccff, transparent: true, opacity: 0.6 });
      for (let wy = 2; wy < bh - 2; wy += 3.5) {
        for (let wx = -bw / 2 + 2; wx < bw / 2; wx += 3) {
          const win = new THREE.Mesh(new THREE.PlaneGeometry(1.4, 1.8), winMat);
          win.position.set(wx, wy, bd / 2 + 0.01); group.add(win);
        }
      }
    }

    // Door pivot
    const doorPivot = new THREE.Group();
    doorPivot.position.set(-1, 0, bd / 2 + 0.01);
    const doorMesh = new THREE.Mesh(
      new THREE.BoxGeometry(1.8, 3, 0.1),
      new THREE.MeshLambertMaterial({ color: 0x5c3a1e })
    );
    doorMesh.position.set(0.9, 1.5, 0);
    doorPivot.add(doorMesh); group.add(doorPivot);

    // Door frame
    const dfMesh = new THREE.Mesh(
      new THREE.BoxGeometry(2.2, 3.2, 0.15),
      new THREE.MeshLambertMaterial({ color: 0x3a2010 })
    );
    dfMesh.position.set(0, 1.6, bd / 2 + 0.02); group.add(dfMesh);

    group.position.set(bx, 0, bz);
    scene.add(group);

    // Physics box
    const b = new CANNON.Body({ mass: 0 });
    b.addShape(new CANNON.Box(new CANNON.Vec3(bw / 2, bh / 2, bd / 2)));
    b.position.set(bx, bh / 2, bz);
    world.addBody(b);

    buildings.push({
      group, doorPivot, doorOpen: false, doorAngle: 0, doorOpening: false,
      worldPos: new THREE.Vector3(bx, 0, bz),
      exitPos: new THREE.Vector3(bx, 0.5, bz + bd / 2 + 5),
      halfD: bd / 2, halfH: bh / 2, label: 'Building ' + (i + 1),
      interior: null
    });
  }
}

