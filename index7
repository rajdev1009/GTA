// ── CUSTOM LAYOUT (drag & drop) ───────────────────────────────
const LAYOUT_KEY='at_layout_v4';
const DRAG_IDS=['joy-zone','act-zone'];
let layoutMode=false;

function applyLayout() {
  try{
    const d=JSON.parse(localStorage.getItem(LAYOUT_KEY)||'{}');
    Object.entries(d).forEach(([id,pos])=>{
      const el=document.getElementById(id);if(!el)return;
      el.style.position='fixed';
      el.style.left=pos.left+'px';el.style.right='auto';
      el.style.top=pos.top+'px';el.style.bottom='auto';
    });
  }catch(e){}
}
function saveLayout() {
  if(OWNER!=='Raj Dev')return;
  const d={};
  DRAG_IDS.forEach(id=>{const el=document.getElementById(id);if(!el)return;const r=el.getBoundingClientRect();d[id]={left:r.left,top:r.top};});
  localStorage.setItem(LAYOUT_KEY,JSON.stringify(d));
}
function resetLayout() {
  localStorage.removeItem(LAYOUT_KEY);
  document.getElementById('joy-zone').style.cssText='position:fixed;bottom:20px;left:20px;width:114px;height:114px;z-index:300;pointer-events:all;touch-action:none';
  document.getElementById('act-zone').style.cssText='position:fixed;bottom:20px;right:14px;z-index:300;pointer-events:all;display:flex;flex-direction:column;align-items:flex-end;gap:7px';
  toast('Layout reset ↺');
}
function startLayoutMode() {
  if(OWNER!=='Raj Dev'){toast('Security: layout locked.');return;}
  layoutMode=true;
  toast('🕹 Drag controls — then open ⚙ Settings > Save',4500);
  DRAG_IDS.forEach(id=>{
    const el=document.getElementById(id);if(!el)return;
    el.classList.add('drag-border');el.style.zIndex='5200';
    const lbl=document.createElement('div');lbl.className='drag-lbl';
    lbl.textContent='✥ '+(id==='joy-zone'?'JOYSTICK':'BUTTONS');
    el.appendChild(lbl);
    makeDraggable(el);
  });
}
function stopLayoutMode() {
  layoutMode=false;
  DRAG_IDS.forEach(id=>{
    const el=document.getElementById(id);if(!el)return;
    el.classList.remove('drag-border');el.style.zIndex='300';
    const l=el.querySelector('.drag-lbl');if(l)l.remove();
  });
}
function makeDraggable(el) {
  let sX,sY,oL,oT,actTid=null,mDwn=false;
  function start(cx,cy){const r=el.getBoundingClientRect();oL=r.left;oT=r.top;sX=cx;sY=cy;el.style.position='fixed';el.style.left=oL+'px';el.style.top=oT+'px';el.style.right='auto';el.style.bottom='auto';}
  function move(cx,cy){el.style.left=Math.max(0,Math.min(innerWidth-el.offsetWidth,oL+(cx-sX)))+'px';el.style.top=Math.max(0,Math.min(innerHeight-el.offsetHeight,oT+(cy-sY)))+'px';}
  el.addEventListener('touchstart',e=>{if(!layoutMode)return;e.stopPropagation();e.preventDefault();actTid=e.changedTouches[0].identifier;start(e.changedTouches[0].clientX,e.changedTouches[0].clientY);},{passive:false});
  document.addEventListener('touchmove',e=>{if(!layoutMode||actTid===null)return;const t=[...e.changedTouches].find(t=>t.identifier===actTid);if(t){e.preventDefault();move(t.clientX,t.clientY);}},{passive:false});
  document.addEventListener('touchend',e=>{if([...e.changedTouches].find(t=>t.identifier===actTid))actTid=null;});
  el.addEventListener('mousedown',e=>{if(!layoutMode)return;e.stopPropagation();mDwn=true;start(e.clientX,e.clientY);});
  document.addEventListener('mousemove',e=>{if(!mDwn||!layoutMode)return;move(e.clientX,e.clientY);});
  document.addEventListener('mouseup',()=>mDwn=false);
}

// ── MINIMAP ──────────────────────────────────────────────────
const mmCtx=document.getElementById('mm-cv').getContext('2d');
const MMS=80/600;
function drawMinimap(){
  mmCtx.clearRect(0,0,80,80);
  mmCtx.fillStyle='rgba(12,18,32,.8)';mmCtx.beginPath();mmCtx.arc(40,40,40,0,Math.PI*2);mmCtx.fill();
  mmCtx.strokeStyle='#2a2a40';mmCtx.lineWidth=1.5;
  for(let i=-4;i<=4;i++){
    mmCtx.beginPath();mmCtx.moveTo(40+i*80*MMS,0);mmCtx.lineTo(40+i*80*MMS,80);mmCtx.stroke();
    mmCtx.beginPath();mmCtx.moveTo(0,40+i*80*MMS);mmCtx.lineTo(80,40+i*80*MMS);mmCtx.stroke();
  }
  vehicles.forEach((v,i)=>{
    const cols=['#ff4444','#4466ff','#ff8844','#44cc88'];
    mmCtx.fillStyle=cols[i%cols.length];
    mmCtx.beginPath();mmCtx.arc(40+v.body.position.x*MMS,40+v.body.position.z*MMS,2.5,0,Math.PI*2);mmCtx.fill();
  });
  if(heliBody){mmCtx.fillStyle='#44ff88';mmCtx.beginPath();mmCtx.arc(40+heliBody.position.x*MMS,40+heliBody.position.z*MMS,2.5,0,Math.PI*2);mmCtx.fill();}
  mmCtx.fillStyle='#ffcc44';
  npcs.forEach(n=>{
    if(n.state==='dead')return;
    const nx=40+n.g.position.x*MMS,nz=40+n.g.position.z*MMS;
    mmCtx.beginPath();mmCtx.arc(nx,nz,1.4,0,Math.PI*2);
    mmCtx.fillStyle=n.state==='angry'?'#ff4455':'#ffcc44';
    mmCtx.fill();
  });
  if(pBody){
    const px=40+pBody.position.x*MMS,pz=40+pBody.position.z*MMS;
    mmCtx.fillStyle='#fff';mmCtx.beginPath();mmCtx.arc(px,pz,3,0,Math.PI*2);mmCtx.fill();
    mmCtx.strokeStyle='#7efff5';mmCtx.lineWidth=1.5;
    mmCtx.beginPath();mmCtx.moveTo(px,pz);mmCtx.lineTo(px-Math.sin(G.camYaw)*8,pz-Math.cos(G.camYaw)*8);mmCtx.stroke();
  }
  mmCtx.globalCompositeOperation='destination-in';mmCtx.beginPath();mmCtx.arc(40,40,40,0,Math.PI*2);mmCtx.fill();
  mmCtx.globalCompositeOperation='source-over';
}

// ── MAIN LOOP ─────────────────────────────────────────────────
const FIXED=1/60;let lastT=null;
function loop(t){
  requestAnimationFrame(loop);
  const dt=lastT===null?FIXED:Math.min((t-lastT)/1000,.05);lastT=t;
  if(!G.alive){renderer.render(scene,camera);return;}
  world.step(FIXED,dt,3);
  updatePlayer(dt);
  updateVehicles(dt);
  updateHeli(dt);
  updateDoors(dt);
  updateNPCs(dt);
  updateNPCHUDs();
  updateCamera();
  document.getElementById('hp-bar').style.width=G.hp+'%';
  drawMinimap();
  renderer.render(scene,camera);
}

