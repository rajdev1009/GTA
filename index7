const npcs=[];
const NPC_NAMES=['Alex','Maya','Sam','Jordan','Riley','Dana','Morgan','Lee','Pat','Sky','Kai','Noa'];
const NPC_SHIRT_COLS=[0x4455dd,0xdd4455,0x44dd99,0xdd9944,0x9944dd,0xdd44aa,0x44aadd,0xaadd44];
const FEMALE_HAIR=[0xffd700,0x5c3a1e,0x000000,0xff6688];
const MALE_HAIR  =[0x3a2010,0x1a1a1a,0x8b6040,0x552200];

function buildNPCModel(female=false) {
  const g=new THREE.Group();
  const skinColor=female?0xffe0c0:0xd4956a;
  const skinM=new THREE.MeshLambertMaterial({color:skinColor});
  // Torso
  const torsoH=female?1.0:1.1;
  const torsoW=female?0.28:0.33;
  const torso=new THREE.Mesh(new THREE.BoxGeometry(torsoW*2,torsoH,torsoW*2*.8),new THREE.MeshLambertMaterial({color:NPC_SHIRT_COLS[Math.floor(Math.random()*NPC_SHIRT_COLS.length)]}));
  g.add(torso);
  // Legs
  const legColor=female?0x223344:0x333322;
  const legM=new THREE.MeshLambertMaterial({color:legColor});
  [-0.14,0.14].forEach(lx=>{const leg=new THREE.Mesh(new THREE.BoxGeometry(.13,.55,.13),legM);leg.position.set(lx,-.77,0);g.add(leg);});
  // Head
  const head=new THREE.Mesh(new THREE.SphereGeometry(.28,8,8),skinM);head.position.y=.72;g.add(head);
  // Hair
  const hairCols=female?FEMALE_HAIR:MALE_HAIR;
  const hairM=new THREE.MeshLambertMaterial({color:hairCols[Math.floor(Math.random()*hairCols.length)]});
  if(female){
    // Long hair
    const hair=new THREE.Mesh(new THREE.CylinderGeometry(.28,.25,.4,8),hairM);hair.position.set(0,.85,-.06);g.add(hair);
    // Skirt
    const skirt=new THREE.Mesh(new THREE.ConeGeometry(.32,.35,8),new THREE.MeshLambertMaterial({color:0xff88aa}));skirt.position.y=-.6;g.add(skirt);
  } else {
    const hair=new THREE.Mesh(new THREE.SphereGeometry(.3,8,6),hairM);hair.position.y=.88;g.add(hair);
  }
  return g;
}

function spawnNPC(x,z,name,female=false,state='idle') {
  const g=buildNPCModel(female);
  g.position.set(x, GROUND_Y+.85, z);   // FIXED: exact ground placement
  scene.add(g);
  const hudEl=document.createElement('div');hudEl.className='npc-hud';
  hudEl.innerHTML=`<div class="npc-nm">${name}</div><div class="nbar-o"><div class="nbar-i" style="width:100%"></div></div>`;
  document.body.appendChild(hudEl);
  const npc={
    g,hudEl,barEl:hudEl.querySelector('.nbar-i'),
    name,hp:100,female,
    state,          // 'idle'|'wandering'|'fleeing'|'angry'|'driving'|'dead'
    idleT:Math.random()*3,
    walkDir:new THREE.Vector3(Math.random()*2-1,0,Math.random()*2-1).normalize(),
    target:null,    // THREE.Vector3 chase target (player pos for angry)
    vehRef:null,    // vehicle they're driving
    stateIcon:null,
    legPhase:Math.random()*Math.PI*2,
  };
  npcs.push(npc);
  return npc;
}

function buildNPCInCar(carGroup) {
  // Simplified NPC visible in driver seat
  const fem=Math.random()>.5;
  const skinC=fem?0xffe0c0:0xd4956a;
  const npcM=new THREE.Group();
