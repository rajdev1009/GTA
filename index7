// ── BUTTON WIRING ─────────────────────────────────────────────
function wire(id,dn,up){
  const el=document.getElementById(id);if(!el)return;
  el.addEventListener('touchstart',e=>{e.stopPropagation();e.preventDefault();dn&&dn();},{passive:false});
  el.addEventListener('touchend',  e=>{e.stopPropagation();e.preventDefault();up&&up();},{passive:false});
  el.addEventListener('mousedown',()=>dn&&dn());
  el.addEventListener('mouseup',  ()=>up&&up());
}
