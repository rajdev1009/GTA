<!--
  ================================================================
  SECURITY ANCHOR — DO NOT REMOVE, HIDE, OR EDIT
  const OWNER = "Raj Dev" is verified against this element
  Hiding via CSS triggers LICENSE EXPIRED and freezes all movement
  ================================================================
-->
<div id="dev-credit">Raj Dev</div>

<script>
'use strict';
/* ================================================================
   ASTRATOONIX OPEN WORLD ENGINE v4.0
   Author : Raj Dev
   Fixes  : Ground clipping, driving physics, joystick inversion,
            camera sensitivity, carjacking, NPC variety, billboards
================================================================ */

// ── SECURITY ──────────────────────────────────────────────────
const OWNER      = "Raj Dev";
const OWNER_GAME = "AstraToonix";

function checkLicense() {
  const el = document.getElementById('dev-credit');
  if (!el || el.textContent.trim() !== OWNER) return false;
  const cs = getComputedStyle(el);
  if (cs.display === 'none' || cs.visibility === 'hidden' || parseFloat(cs.opacity) < 0.01) return false;
  return true;
}

let licenseOk = true;
setInterval(() => {
  const ok = checkLicense();
  if (!ok && licenseOk) {
    licenseOk = false;
    document.getElementById('lic-ov').classList.add('show');
    G.alive = false;
  }
  licenseOk = ok;
}, 1000);

// ── SETTINGS SLIDERS ─────────────────────────────────────────
let camSens   = 5;   // 1–10 → mapped to 0.001–0.008 rad/px
let moveSpeed = 8;   // units/s

function sensToRad(s)  { return 0.001 + (s - 1) * 0.0008; }

const sensSlider  = document.getElementById('sens-slider');
const speedSlider = document.getElementById('speed-slider');
sensSlider.addEventListener('input', () => {
  camSens = +sensSlider.value;
  document.getElementById('sens-val').textContent = camSens;
  localStorage.setItem('at_sens', camSens);
});
speedSlider.addEventListener('input', () => {
  moveSpeed = +speedSlider.value;
  document.getElementById('speed-val').textContent = moveSpeed;
  localStorage.setItem('at_speed', moveSpeed);
});
// Restore saved prefs
try {
  const ss = +localStorage.getItem('at_sens');  if(ss) { camSens=ss;   sensSlider.value=ss;   document.getElementById('sens-val').textContent=ss; }
  const sv = +localStorage.getItem('at_speed'); if(sv) { moveSpeed=sv; speedSlider.value=sv;  document.getElementById('speed-val').textContent=sv; }
} catch(e){}

// ── PORTRAIT ─────────────────────────────────────────────────
let portOk = false;
document.getElementById('port-ok').addEventListener('click', () => { portOk=true; document.getElementById('port-ov').classList.remove('show'); });
function chkOrient() {
  if (portOk) return;
  document.getElementById('port-ov').classList.toggle('show', innerHeight > innerWidth + 60);
}
window.addEventListener('resize', chkOrient);
window.addEventListener('orientationchange', () => setTimeout(chkOrient,300));
setTimeout(chkOrient, 900);

// ── LOADING ──────────────────────────────────────────────────
function setLoad(p, t) {
  document.getElementById('lb-i').style.width = p+'%';
  if (t) document.getElementById('ls-tip').textContent = t;
}
const sleep = ms => new Promise(r=>setTimeout(r,ms));

// ── SOUND ────────────────────────────────────────────────────
const SFX = (() => {
  let AC=null, eO=null, eG=null, eOn=false, rO=null, rG=null, rOn=false;
  function ctx() {
    if (!AC) AC = new (window.AudioContext||window.webkitAudioContext)();
    if (AC.state==='suspended') AC.resume().catch(()=>{});
    return AC;
  }
  function beep(f,d,type='sine',v=0.08){
    try{const c=ctx(),o=c.createOscillator(),g=c.createGain();
    o.type=type;o.frequency.setValueAtTime(f,c.currentTime);
    g.gain.setValueAtTime(v,c.currentTime);g.gain.exponentialRampToValueAtTime(0.0001,c.currentTime+d);
    o.connect(g);g.connect(c.destination);o.start();o.stop(c.currentTime+d);}catch(e){}}
  return {
    foot(road){beep(road?120+Math.random()*40:150+Math.random()*40,0.07,'triangle',.03);},
    startEng(){if(eOn)return;try{const c=ctx();eO=c.createOscillator();eG=c.createGain();eO.type='sawtooth';eO.frequency.setValueAtTime(55,c.currentTime);eG.gain.setValueAtTime(.06,c.currentTime);eO.connect(eG);eG.connect(c.destination);eO.start();eOn=true;}catch(e){}},
    stopEng(){if(!eOn)return;try{eG.gain.exponentialRampToValueAtTime(.0001,ctx().currentTime+.4);eO.stop(ctx().currentTime+.5);}catch(e){};eOn=false;eO=null;eG=null;},
    revEng(t){if(!eO||!eOn)return;try{eO.frequency.setValueAtTime(55+t*220,ctx().currentTime);}catch(e){}},
    startRot(){if(rOn)return;try{const c=ctx();rO=c.createOscillator();rG=c.createGain();rO.type='square';rO.frequency.setValueAtTime(28,c.currentTime);rG.gain.setValueAtTime(.09,c.currentTime);rO.connect(rG);rG.connect(c.destination);rO.start();rOn=true;}catch(e){}},
    stopRot(){if(!rOn)return;try{rG.gain.exponentialRampToValueAtTime(.0001,ctx().currentTime+1);rO.stop(ctx().currentTime+1.2);}catch(e){};rOn=false;},
    revRot(t){if(!rO||!rOn)return;try{rO.frequency.setValueAtTime(28+t*60,ctx().currentTime);}catch(e){}},
    startCity(){try{const c=ctx(),o=c.createOscillator(),g=c.createGain();o.type='sine';o.frequency.setValueAtTime(80,c.currentTime);g.gain.setValueAtTime(.02,c.currentTime);o.connect(g);g.connect(c.destination);o.start();}catch(e){}},
    hit()   {beep(90,.08,'square',.1);},
    jump()  {beep(260,.1,'sine',.06);},
    door()  {beep(200,.12,'triangle',.07);},
    scream(){beep(850,.22,'sawtooth',.09);setTimeout(()=>beep(620,.18,'sawtooth',.06),110);},
    horn()  {beep(440,.3,'square',.14);}
  };
})();

// ── UI HELPERS ───────────────────────────────────────────────
let toastTmr=null;
function toast(msg, dur=2800) {
  const el=document.getElementById('toast');
  el.textContent=msg;el.classList.add('show');
  clearTimeout(toastTmr);toastTmr=setTimeout(()=>el.classList.remove('show'),dur);
}
let zoneTmr=null;
function flashZone(name) {
  const el=document.getElementById('zone-flash');
  el.textContent=name;el.classList.add('show');
  document.getElementById('hud-zone').textContent=name;
  clearTimeout(zoneTmr);zoneTmr=setTimeout(()=>el.classList.remove('show'),3200);
}
function fadeIn(cb) {
  const ov=document.getElementById('fade-ov');ov.classList.add('on');
  setTimeout(()=>{cb();ov.classList.remove('on');},440);
}
function showCJFlash() {
  const el=document.getElementById('cj-flash');el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),1200);
}

// ── GAME STATE ───────────────────────────────────────────────
const G = {
  alive: false,
  vehicle: null,        // null | 'car' | 'bike' | 'heli'
  vehIdx: -1,           // index into vehicles[] for occupied car/bike
  inside: false,
  insideBldIdx: -1,
  hp: 100,
  lights: false,
  keys: {w:false,a:false,s:false,d:false},
  joy: {x:0,y:0},
  camYaw: 0,
  camPitch: 0.32
};

// ── THREE.JS ─────────────────────────────────────────────────
const canvas   = document.getElementById('game-canvas');
const renderer = new THREE.WebGLRenderer({canvas, antialias:false, powerPreference:'high-performance'});
renderer.setPixelRatio(Math.min(devicePixelRatio,1.5));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type    = THREE.PCFSoftShadowMap;

const scene = new THREE.Scene();
