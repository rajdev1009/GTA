// ── CAR BUILDER ──────────────────────────────────────────────
const CAR_HALF_H  = 0.35;  // physics box half-height
const BIKE_HALF_H = 0.28;

function buildCar(x, z, hasNPC=false) {
  const g=new THREE.Group();
  const ch=new THREE.Mesh(new THREE.BoxGeometry(2.2,.6,4.4),new THREE.MeshLambertMaterial({color:0xee2222}));ch.castShadow=true;g.add(ch);
  const ca=new THREE.Mesh(new THREE.BoxGeometry(1.8,.65,2.2),new THREE.MeshLambertMaterial({color:0xcc2222}));ca.position.set(0,.62,-.2);g.add(ca);
  const wGeo=new THREE.CylinderGeometry(.4,.4,.28,12);wGeo.rotateZ(Math.PI/2);
  const wMat=new THREE.MeshLambertMaterial({color:0x111122});
  const wls=[];
  [[-1.2,-.28,-1.5],[1.2,-.28,-1.5],[-1.2,-.28,1.5],[1.2,-.28,1.5]].forEach(p=>{
    const w=new THREE.Mesh(wGeo,wMat);w.position.set(...p);g.add(w);wls.push(w);
  });
  const lts=[];
  [-0.7,0.7].forEach(sx=>{
    const s=new THREE.SpotLight(0xffffcc,0,40,Math.PI/9,.3);
    s.position.set(sx,.2,-2.3);s.target.position.set(sx,-1,-15);
    g.add(s);g.add(s.target);lts.push(s);
  });

  // FIXED: place exactly on ground, accounting for geometry center + half-height
  const bodyY = GROUND_Y + CAR_HALF_H + 0.05;
  const meshY = GROUND_Y + 0.05;
  g.position.set(x, meshY, z);
  scene.add(g);

  const body=new CANNON.Body({mass:950,linearDamping:.55,angularDamping:.85});
  body.addShape(new CANNON.Box(new CANNON.Vec3(1.1,CAR_HALF_H,2.2)));
  body.position.set(x,bodyY,z);
  body.fixedRotation=false;
  world.addBody(body);

  let npc=null;
  if(hasNPC){
    npc=buildNPCInCar(g);
  }

  const veh={type:'car',group:g,body,wheels:wls,lights:lts,occupied:hasNPC,npc,speed:0,steer:0,wheelRot:0};
  vehicles.push(veh);
  return veh;
}

