<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<title>AstraToonix v4 – Raj Dev</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cannon.js/0.6.2/cannon.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:#000;font-family:'Rajdhani',sans-serif;touch-action:none;user-select:none;-webkit-user-select:none}
#game-canvas{position:fixed;inset:0;display:block;width:100%!important;height:100%!important}

/* LOADING */
#ls{position:fixed;inset:0;z-index:10000;background:#06060f;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;transition:opacity .6s}
#ls.out{opacity:0;pointer-events:none}
#ls h1{font-family:'Orbitron',monospace;font-size:clamp(1.4rem,6vw,2.5rem);color:#7efff5;letter-spacing:6px;text-shadow:0 0 40px #7efff5;animation:glw 2s ease infinite;text-align:center}
#ls .sub{font-family:'Orbitron',monospace;font-size:.55rem;color:#336;letter-spacing:3px}
@keyframes glw{0%,100%{text-shadow:0 0 40px #7efff5}50%{text-shadow:0 0 100px #7efff5,0 0 160px #7efff540}}
#lb-o{width:min(300px,72vw);height:5px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden}
#lb-i{height:100%;width:0%;background:linear-gradient(90deg,#7efff5,#64c8ff);border-radius:3px;transition:width .3s ease}
#ls-tip{font-family:'Rajdhani',sans-serif;font-size:.78rem;color:#445;letter-spacing:2px}

/* PORTRAIT */
#port-ov{display:none;position:fixed;inset:0;z-index:9100;background:linear-gradient(135deg,#0d0d1f,#1a0a2e);flex-direction:column;align-items:center;justify-content:center;gap:18px}
#port-ov.show{display:flex}
#port-ov h2{font-family:'Orbitron',monospace;color:#7efff5;font-size:clamp(.9rem,5vw,1.3rem);text-align:center;letter-spacing:2px}
#port-ov button{background:rgba(126,255,245,.1);border:2px solid #7efff5;color:#7efff5;font-family:'Orbitron',monospace;font-size:.62rem;letter-spacing:2px;padding:10px 22px;border-radius:6px;cursor:pointer}
.ri{font-size:60px;animation:rotA 1.8s ease-in-out infinite}
@keyframes rotA{0%,100%{transform:rotate(0)}40%,60%{transform:rotate(90deg)}}

/* LICENSE */
#lic-ov{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.97);flex-direction:column;align-items:center;justify-content:center;gap:14px}
#lic-ov.show{display:flex}
#lic-ov h2{font-family:'Orbitron',monospace;color:#ff4455;font-size:clamp(1rem,4vw,1.5rem);letter-spacing:4px;text-shadow:0 0 30px #ff4455;animation:glw2 1.5s ease infinite}
@keyframes glw2{0%,100%{text-shadow:0 0 30px #ff4455}50%{text-shadow:0 0 70px #ff4455,0 0 110px #ff445550}}
#lic-ov p{color:#8899bb;font-size:.8rem;letter-spacing:1px}
#lic-ov small{color:#ff445590;font-size:.56rem;letter-spacing:2px}

/* HUD */
#hud{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:linear-gradient(180deg,rgba(0,0,0,.7) 0%,transparent 100%);pointer-events:none}
.hl{font-family:'Orbitron',monospace;font-size:.5rem;color:#7efff5;letter-spacing:2px}
.hpw{width:110px;height:7px;background:rgba(255,255,255,.1);border-radius:4px;overflow:hidden}
#hp-bar{height:100%;width:100%;background:linear-gradient(90deg,#00ff88,#7efff5);border-radius:4px;transition:width .3s}
#hud-title{font-family:'Orbitron',monospace;font-size:clamp(.48rem,2.2vw,.7rem);color:#fff;letter-spacing:3px;text-shadow:0 0 10px #7efff5}
#hud-zone{font-family:'Orbitron',monospace;font-size:.5rem;color:#ffcc44;letter-spacing:1px;text-align:right}

/* SETTINGS GEAR */
#gear-btn{position:fixed;top:8px;right:8px;z-index:600;width:36px;height:36px;border-radius:50%;background:rgba(0,0,0,.6);border:1px solid rgba(126,255,245,.35);display:flex;align-items:center;justify-content:center;cursor:pointer;pointer-events:all;font-size:1.1rem;-webkit-tap-highlight-color:transparent;transition:transform .3s;backdrop-filter:blur(8px)}
#gear-btn:hover{transform:rotate(60deg)}

/* SETTINGS PANEL */
#settings-ov{display:none;position:fixed;inset:0;z-index:5000;background:rgba(0,5,18,.88);backdrop-filter:blur(6px)}
#settings-ov.show{display:block}
#set-panel{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:min(340px,90vw);background:rgba(5,10,25,.95);border:1px solid rgba(126,255,245,.25);border-radius:12px;padding:22px;display:flex;flex-direction:column;gap:14px}
#set-panel h2{font-family:'Orbitron',monospace;font-size:.85rem;color:#7efff5;letter-spacing:3px;text-align:center;text-shadow:0 0 12px #7efff580}
.set-row{display:flex;align-items:center;justify-content:space-between;gap:10px}
.set-label{font-family:'Rajdhani',sans-serif;font-size:.82rem;color:#aabbcc;letter-spacing:1px}
.set-val{font-family:'Orbitron',monospace;font-size:.65rem;color:#7efff5;min-width:32px;text-align:right}
input[type=range]{flex:1;accent-color:#7efff5;height:4px;cursor:pointer}
.set-divider{height:1px;background:rgba(126,255,245,.1);margin:2px 0}
.set-footer{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:4px}
.sbtn{font-family:'Orbitron',monospace;font-size:.55rem;letter-spacing:1px;padding:8px 16px;border-radius:6px;cursor:pointer;-webkit-tap-highlight-color:transparent}
#s-layout{background:rgba(126,255,245,.12);border:1.5px solid #7efff5;color:#7efff5}
#s-save{background:rgba(100,200,100,.12);border:1.5px solid #44cc88;color:#44cc88}
#s-reset{background:rgba(255,68,85,.1);border:1.5px solid #ff4455;color:#ff4455}
#s-close{background:rgba(255,204,68,.1);border:1.5px solid #ffcc44;color:#ffcc44}

/* LAYOUT MODE */
.drag-border{outline:2px dashed rgba(126,255,245,.6)!important;border-radius:10px}
.drag-lbl{position:absolute;top:-20px;left:50%;transform:translateX(-50%);font-family:'Orbitron',monospace;font-size:.34rem;color:#7efff5;background:rgba(0,0,0,.8);padding:2px 6px;border-radius:3px;white-space:nowrap;pointer-events:none;letter-spacing:1px}

/* ZONE FLASH */
#zone-flash{position:fixed;top:50px;left:50%;transform:translateX(-50%);z-index:210;font-family:'Orbitron',monospace;font-size:clamp(.65rem,3vw,.95rem);color:#fff;letter-spacing:4px;text-shadow:0 0 20px #7efff5;opacity:0;transition:opacity .5s;pointer-events:none;white-space:nowrap}
#zone-flash.show{opacity:1}

/* TOAST */
#toast{position:fixed;top:62px;left:50%;transform:translateX(-50%);z-index:210;background:rgba(0,0,0,.85);border:1px solid #7efff530;border-radius:8px;padding:6px 16px;font-family:'Rajdhani',sans-serif;font-size:.8rem;color:#7efff5;letter-spacing:1px;opacity:0;pointer-events:none;transition:opacity .3s;white-space:nowrap;backdrop-filter:blur(8px)}
#toast.show{opacity:1}

/* VEHICLE HUD */
#vhud{position:fixed;bottom:130px;right:16px;z-index:210;display:none;flex-direction:column;align-items:flex-end;gap:3px}
#vhud.show{display:flex}
#spd{font-family:'Orbitron',monospace;font-size:clamp(1.2rem,6vw,2rem);color:#ffcc44;text-shadow:0 0 12px #ffcc4480}
#spd-u{font-size:.6rem;color:#8899bb;letter-spacing:2px}
#lights-btn{background:rgba(0,0,0,.6);border:1px solid #ffcc44;color:#ffcc44;font-family:'Orbitron',monospace;font-size:.46rem;letter-spacing:1px;padding:4px 10px;border-radius:4px;cursor:pointer;pointer-events:all;-webkit-tap-highlight-color:transparent}

/* ALTITUDE */
#alt-hud{position:fixed;bottom:130px;left:144px;z-index:210;display:none;flex-direction:column;align-items:flex-start;gap:2px}
#alt-hud.show{display:flex}
#alt-val{font-family:'Orbitron',monospace;font-size:1.1rem;color:#7efff5;text-shadow:0 0 10px #7efff580}
#alt-u{font-size:.55rem;color:#8899bb;letter-spacing:2px}

/* FADE */
#fade-ov{position:fixed;inset:0;z-index:700;background:#000;opacity:0;pointer-events:none;transition:opacity .4s}
#fade-ov.on{opacity:1;pointer-events:all}

/* CARJACK FLASH */
#cj-flash{position:fixed;top:40%;left:50%;transform:translate(-50%,-50%);z-index:500;font-family:'Orbitron',monospace;font-size:clamp(1rem,5vw,1.6rem);color:#ff4455;letter-spacing:4px;text-shadow:0 0 30px #ff4455;opacity:0;pointer-events:none;transition:opacity .2s;white-space:nowrap}
#cj-flash.show{opacity:1}

/* JOYSTICK */
#joy-zone{position:fixed;bottom:20px;left:20px;width:114px;height:114px;z-index:300;pointer-events:all;touch-action:none}
#joy-base{width:114px;height:114px;border-radius:50%;background:rgba(126,255,245,.07);border:2px solid rgba(126,255,245,.22);position:relative}
#joy-thumb{width:44px;height:44px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#7efff5,#1a8888);border:2px solid rgba(255,255,255,.2);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);box-shadow:0 0 14px #7efff540}

/* ACTION BUTTONS */
#act-zone{position:fixed;bottom:20px;right:14px;z-index:300;pointer-events:all;display:flex;flex-direction:column;align-items:flex-end;gap:7px}
.ar{display:flex;gap:7px}
.abtn{width:48px;height:48px;border-radius:50%;border:2px solid rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:.44rem;color:#fff;cursor:pointer;backdrop-filter:blur(6px);-webkit-tap-highlight-color:transparent;transition:transform .1s;touch-action:none}
.abtn:active{transform:scale(.87)}
#b-jump{background:rgba(126,255,245,.15);border-color:#7efff5}
#b-enter{background:rgba(255,204,68,.15);border-color:#ffcc44}
#b-attack{background:rgba(255,68,85,.15);border-color:#ff4455}
#b-down{background:rgba(180,100,255,.15);border-color:#b464ff}

/* NPC HUDS */
.npc-hud{position:fixed;z-index:220;pointer-events:none;display:flex;flex-direction:column;align-items:center;gap:2px}
.npc-nm{font-family:'Rajdhani',sans-serif;font-size:.56rem;color:#fff;letter-spacing:1px;text-shadow:0 1px 4px #000}
.nbar-o{width:52px;height:5px;background:rgba(0,0,0,.5);border-radius:3px;overflow:hidden;border:1px solid rgba(255,255,255,.15)}
.nbar-i{height:100%;background:#ff4455;border-radius:3px;transition:width .3s}
.npc-state{font-size:.68rem;animation:fps .45s ease infinite alternate}
@keyframes fps{from{transform:scale(1)}to{transform:scale(1.3)}}

/* MINIMAP */
#minimap{position:fixed;top:46px;right:12px;z-index:210;width:80px;height:80px;border-radius:50%;overflow:hidden;pointer-events:none;border:1px solid rgba(126,255,245,.2)}
#mm-cv{width:80px;height:80px}

/* DEV CREDIT — SECURITY ANCHOR */
#dev-credit{position:fixed;bottom:5px;left:50%;transform:translateX(-50%);z-index:250;font-family:'Orbitron',monospace;font-size:.4rem;color:rgba(126,255,245,.3);letter-spacing:2px;pointer-events:none}
</style>
</head>
