function damageNearNPC(skipFear=false) {
  const pp=new THREE.Vector3(pBody.position.x,pBody.position.y,pBody.position.z);
  let nearest=null,minD=5;
  npcs.forEach(n=>{
    if(n.dead||n.state==='dead'||n.state==='driving')return;
    const d=n.g.position.distanceTo(pp);
    if(d<minD){minD=d;nearest=n;}
  });
  if(!nearest){if(!skipFear)toast('No one nearby!');return null;}
  nearest.hp-=25;
  if(!skipFear){
    nearest.state='fleeing';nearest.idleT=7;
    nearest.walkDir.set(nearest.g.position.x-pp.x,0,nearest.g.position.z-pp.z).normalize();
    setNPCIcon(nearest,'😱');SFX.scream();SFX.hit();
  }
  nearest.barEl.style.width=Math.max(0,nearest.hp)+'%';
  if(nearest.hp<=0){
    nearest.state='dead';nearest.g.visible=false;nearest.hudEl.style.display='none';
    toast(nearest.name+' is down!');
  } else if(!skipFear) {
    toast(nearest.name+': '+nearest.hp+'HP — FLEEING!');
  }
  return nearest;
}

function setNPCIcon(npc,icon) {
