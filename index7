function updateNPCs(dt) {
  const pp=new THREE.Vector3(pBody.position.x,pBody.position.y,pBody.position.z);
  npcs.forEach(n=>{
    if(n.state==='dead'||n.state==='driving')return;
    const spd = (n.state==='fleeing'||n.state==='angry')?5.5:1.5;

    if(n.state==='fleeing'){
      n.idleT-=dt;
      if(n.idleT<=0){n.state='wandering';const ic=n.hudEl.querySelector('.npc-state');if(ic)ic.remove();}
      n.g.position.x+=n.walkDir.x*spd*dt;
      n.g.position.z+=n.walkDir.z*spd*dt;
      n.g.rotation.y=Math.atan2(n.walkDir.x,n.walkDir.z);
    } else if(n.state==='angry'){
      // Chase player
      const dir=new THREE.Vector3(pp.x-n.g.position.x,0,pp.z-n.g.position.z).normalize();
      n.g.position.x+=dir.x*spd*dt;
      n.g.position.z+=dir.z*spd*dt;
      n.g.rotation.y=Math.atan2(dir.x,dir.z);
      // Close enough to hit player
      const d=n.g.position.distanceTo(new THREE.Vector3(pp.x,n.g.position.y,pp.z));
      if(d<1.5){
        G.hp=Math.max(0,G.hp-8);SFX.hit();
        if(G.hp<=0){toast('You were knocked out! Respawning…');setTimeout(respawnPlayer,2000);}
      }
    } else {
      // Wandering
      n.idleT-=dt;
      if(n.idleT<=0){
        n.walkDir.set(Math.random()*2-1,0,Math.random()*2-1).normalize();
        n.idleT=2+Math.random()*5;
      }
      n.g.position.x+=n.walkDir.x*spd*dt;
      n.g.position.z+=n.walkDir.z*spd*dt;
      n.g.rotation.y=Math.atan2(n.walkDir.x,n.walkDir.z);
    }

    // Keep strictly on ground
    n.g.position.y = GROUND_Y + .85;
    n.g.position.x=Math.max(-2400,Math.min(2400,n.g.position.x));
    n.g.position.z=Math.max(-2400,Math.min(2400,n.g.position.z));

    // Leg bob
    n.legPhase+=dt*8*(spd>2?1:.5);
  });
}

function respawnPlayer() {
  G.hp=100;G.alive=true;
