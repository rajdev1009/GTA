// ── JOYSTICK ─────────────────────────────────────────────────
const jBase=document.getElementById('joy-base');
const jThumb=document.getElementById('joy-thumb');
let jTid=null;const JR=35;

jBase.addEventListener('touchstart',e=>{e.preventDefault();jTid=e.changedTouches[0].identifier;},{passive:false});
document.addEventListener('touchmove',e=>{
  if(jTid===null)return;
  const t=[...e.changedTouches].find(t=>t.identifier===jTid);if(!t)return;
  e.preventDefault();
  const r=jBase.getBoundingClientRect();
  let dx=t.clientX-(r.left+r.width/2), dy=t.clientY-(r.top+r.height/2);
  const dist=Math.sqrt(dx*dx+dy*dy);if(dist>JR){dx=dx/dist*JR;dy=dy/dist*JR;}
  jThumb.style.transform=`translate(calc(-50% + ${dx}px),calc(-50% + ${dy}px))`;
  // FIXED: joy.x positive=right, joy.y positive=up (raw from DOM: dy<0 when pushed up)
  G.joy.x=dx/JR; G.joy.y=-(dy/JR);  // invert Y so joy.y>0 = forward
},{passive:false});
function resetJoy(){jThumb.style.transform='translate(-50%,-50%)';G.joy.x=G.joy.y=0;jTid=null;}
document.addEventListener('touchend',e=>{if([...e.changedTouches].find(t=>t.identifier===jTid))resetJoy();});

// ── TOUCH-TO-LOOK (right 70%, FIXED inversion + sensitivity) ─
// FIXED: swiping RIGHT increases camYaw (turns right), up = pitch up
let lTid=null,lLX=0,lLY=0;
document.addEventListener('touchstart',e=>{
  for(let i=0;i<e.changedTouches.length;i++){
    const t=e.changedTouches[i];
    if(t.clientX>innerWidth*.30&&t.identifier!==jTid){
      const el=document.elementFromPoint(t.clientX,t.clientY);
      if(el&&(el.classList.contains('abtn')||el.closest('#settings-ov')||el.id==='gear-btn'||el.id==='lights-btn'))continue;
      lTid=t.identifier;lLX=t.clientX;lLY=t.clientY;
    }
  }
},{passive:true});
document.addEventListener('touchmove',e=>{
  if(lTid===null)return;
  const t=[...e.changedTouches].find(t=>t.identifier===lTid);if(!t)return;
  const sensFactor=sensToRad(camSens);
  // FIXED: swiping right (dx>0) increases yaw (turns right), NOT inverted
  G.camYaw  -= (t.clientX-lLX)*sensFactor;  // subtract → right swipe = turns camera right
  G.camPitch += (t.clientY-lLY)*sensFactor;
  G.camPitch=Math.max(-.05,Math.min(Math.PI/2.1,G.camPitch));
  lLX=t.clientX;lLY=t.clientY;
},{passive:true});
document.addEventListener('touchend',e=>{if([...e.changedTouches].find(t=>t.identifier===lTid))lTid=null;});

