const roadMat  = new THREE.MeshLambertMaterial({color:0x222233});
const markMat  = new THREE.MeshBasicMaterial({color:0xffee44});
function buildRoads() {
  const N=28,step=80,len=step*N;
  for(let i=-N/2;i<=N/2;i++){
    const r1=new THREE.Mesh(new THREE.PlaneGeometry(14,len),roadMat);
    r1.rotation.x=-Math.PI/2;r1.position.set(i*step,.016,0);scene.add(r1);
    const r2=new THREE.Mesh(new THREE.PlaneGeometry(len,14),roadMat);
    r2.rotation.x=-Math.PI/2;r2.position.set(0,.016,i*step);scene.add(r2);
    // Dashes
    for(let j=-8;j<=8;j++){
      const m1=new THREE.Mesh(new THREE.PlaneGeometry(.35,5.5),markMat);
      m1.rotation.x=-Math.PI/2;m1.position.set(i*step,.023,j*10);scene.add(m1);
      const m2=new THREE.Mesh(new THREE.PlaneGeometry(5.5,.35),markMat);
      m2.rotation.x=-Math.PI/2;m2.position.set(j*10,.023,i*step);scene.add(m2);
    }
  }
}

// ── BILLBOARD (CanvasTexture) ─────────────────────────────────
function makeBillboard(line1,line2,glowCol) {
  const cv=document.createElement('canvas'); cv.width=512;cv.height=196;
  const c=cv.getContext('2d');
  c.fillStyle='#000814'; c.fillRect(0,0,512,196);
  c.shadowBlur=28; c.shadowColor=glowCol;
  c.strokeStyle=glowCol; c.lineWidth=4; c.strokeRect(5,5,502,186);
  c.shadowBlur=45; c.shadowColor=glowCol;
  c.fillStyle=glowCol; c.font='bold 60px Orbitron,monospace';
  c.textAlign='center'; c.textBaseline='middle'; c.fillText(line1,256,72);
  c.shadowBlur=22; c.shadowColor='#fff';
  c.fillStyle='#ffffff'; c.font='bold 26px Rajdhani,sans-serif';
  c.fillText(line2,256,138);
  [[9,9],[503,9],[9,187],[503,187]].forEach(([x,y])=>{c.beginPath();c.arc(x,y,5,0,Math.PI*2);c.fill();});
  return new THREE.CanvasTexture(cv);
}
function attachBillboard(group, bh, halfD, glowCol) {
  const tex = makeBillboard(OWNER_GAME,'PRO-DEVELOPER: '+OWNER,glowCol);
  const bb  = new THREE.Mesh(new THREE.PlaneGeometry(18,6.5),new THREE.MeshBasicMaterial({map:tex,side:THREE.DoubleSide,toneMapped:false}));
  bb.position.set(0,bh+4.5,halfD+.4); group.add(bb);
  const gl  = new THREE.PointLight(new THREE.Color(glowCol),4,80);
  gl.position.set(0,bh+4.5,halfD+3); group.add(gl);
}

// ── BUILDINGS ────────────────────────────────────────────────
const buildings=[];
const BB_COLORS=['#ff00ff','#00ffff','#ffcc00','#ff6600','#00ff88'];

function buildCity() {
  if (OWNER!=='Raj Dev') return;
  const bCols=[0xc8b090,0x9ab0c8,0xc89090,0x90c8a0,0xd4c080,0xa090c8,0xc0c0c0,0xd08060];
  const rCols=[0x8b3a3a,0x3a5a8b,0x6a3a8b,0x3a8b6a,0x8b7a3a];
  const rng=(()=>{let s=77;return()=>{s=(s*1664525+1013904223)&0xffffffff;return(s>>>0)/0xffffffff;};})();
  let tallest=[];

  for(let i=0;i<222;i++){
    let bx,bz,tries=0;
    do{
      bx=(Math.floor(rng()*28)-14)*80+(rng()-.5)*50;
      bz=(Math.floor(rng()*28)-14)*80+(rng()-.5)*50;
      tries++;
    }while((Math.abs(bx%80)<12||Math.abs(bz%80)<12)&&tries<20);

    const bw=8+rng()*14, bd=8+rng()*14, bh=6+rng()*rng()*96;
    const col=bCols[Math.floor(rng()*bCols.length)];
    const rc =rCols[Math.floor(rng()*rCols.length)];
    const g=new THREE.Group();

    const body=new THREE.Mesh(new THREE.BoxGeometry(bw,bh,bd),new THREE.MeshLambertMaterial({color:col}));
    body.position.y=bh/2;body.castShadow=true;body.receiveShadow=true;g.add(body);
    g.add(Object.assign(new THREE.Mesh(new THREE.BoxGeometry(bw+.5,.7,bd+.5),new THREE.MeshLambertMaterial({color:rc})),{position:{x:0,y:bh+.35,z:0}}));

    if(bh<35){
      const wm=new THREE.MeshLambertMaterial({color:0x88ccff,transparent:true,opacity:.55});
      for(let wy=2.5;wy<bh-2;wy+=3.5)
        for(let wx=-bw/2+2;wx<bw/2-1;wx+=3){
          const wn=new THREE.Mesh(new THREE.PlaneGeometry(1.4,1.8),wm);
          wn.position.set(wx,wy,bd/2+.01);g.add(wn);
        }
    }
    // Door
    const dPiv=new THREE.Group(); dPiv.position.set(-.9,0,bd/2+.01);
    const dM=new THREE.Mesh(new THREE.BoxGeometry(1.8,3,.1),new THREE.MeshLambertMaterial({color:0x5c3a1e}));
    dM.position.set(.9,1.5,0); dPiv.add(dM); g.add(dPiv);
    const df=new THREE.Mesh(new THREE.BoxGeometry(2.2,3.2,.15),new THREE.MeshLambertMaterial({color:0x3a2010}));
    df.position.set(0,1.6,bd/2+.02); g.add(df);

    g.position.set(bx,0,bz); scene.add(g);
    const b=new CANNON.Body({mass:0});
    b.addShape(new CANNON.Box(new CANNON.Vec3(bw/2,bh/2,bd/2)));
    b.position.set(bx,bh/2,bz); world.addBody(b);

    buildings.push({group:g,dPiv,doorAngle:0,doorOpen:false,doorOpening:false,
      pos:new THREE.Vector3(bx,0,bz),exitPos:new THREE.Vector3(bx,.5,bz+bd/2+5),halfD:bd/2,bh,label:'Building '+(i+1)});
    tallest.push({g,bh,halfD:bd/2}); tallest.sort((a,b2)=>b2.bh-a.bh); if(tallest.length>5)tallest.pop();
  }
  tallest.forEach((t,i)=>attachBillboard(t.g,t.bh,t.halfD,BB_COLORS[i%BB_COLORS.length]));
}

// ── STREET PROPS ─────────────────────────────────────────────
function buildProps() {
  const lampM=new THREE.MeshLambertMaterial({color:0x778899});
  const gloM =new THREE.MeshBasicMaterial({color:0xffffcc});
  const trunkM=new THREE.MeshLambertMaterial({color:0x5c3a1e});
  const leafM =new THREE.MeshLambertMaterial({color:0x2d7a27});
  for(let i=-12;i<=12;i++){[-9,9].forEach(side=>{
    const g=new THREE.Group();
    const p=new THREE.Mesh(new THREE.CylinderGeometry(.07,.07,6,6),lampM);p.position.y=3;g.add(p);
    const h=new THREE.Mesh(new THREE.SphereGeometry(.15,6,6),gloM);h.position.y=6;g.add(h);
    const l=new THREE.PointLight(0xffeecc,2,32);l.position.y=5.8;g.add(l);
    g.position.set(side,0,i*80);scene.add(g);
    const g2=g.clone();g2.position.set(i*80,0,side);scene.add(g2);
  });}
  for(let i=0;i<80;i++){
    const x=(Math.random()-.5)*2000, z=(Math.random()-.5)*2000;
    if(Math.abs(x%80)<14||Math.abs(z%80)<14)continue;
    const g=new THREE.Group();
    const tr=new THREE.Mesh(new THREE.CylinderGeometry(.2,.3,2.5,7),trunkM);tr.position.y=1.25;g.add(tr);
    [3,4.2,5.1].forEach((py,idx)=>{
      const f=new THREE.Mesh(new THREE.ConeGeometry((1.8-idx*.35)*1.9,1.7,7),leafM);f.position.y=py;g.add(f);
    });
    g.position.set(x,0,z);scene.add(g);
  }
}

