// ── CAMERA ───────────────────────────────────────────────────
function updateCamera() {
  const tx=pBody.position.x, ty=pBody.position.y+.8, tz=pBody.position.z;
  const dist=G.vehicle==='heli'?18:(G.vehicle?11:G.camDist||9);
  const pitch=Math.max(-.05,Math.min(Math.PI/2.1,G.camPitch));
  const cx=tx+Math.sin(G.camYaw)*Math.cos(pitch)*dist;
  const cy=ty+Math.sin(pitch)*dist;
  const cz=tz+Math.cos(G.camYaw)*Math.cos(pitch)*dist;
  camera.position.set(cx,Math.max(GROUND_Y+.5,cy),cz);
  camera.lookAt(tx,ty,tz);
}

// ── PLAYER MOVEMENT ──────────────────────────────────────────
// FIX: joystick Y is NOT inverted — joy.y>0 means push forward
function updatePlayer(dt) {
  if(!G.alive||G.vehicle)return;
  if(!licenseOk){pBody.velocity.set(0,pBody.velocity.y,0);return;}

  // joy.y: positive = stick pushed up (forward), negative = back
  // joy.x: positive = right, negative = left
  // FIXED INVERSION: forward = -joy.y (push up → move forward)
  let ix=G.joy.x, iz=-G.joy.y;   // iz<0 = forward when joystick pushed up
  if(G.keys.w) iz=-1; if(G.keys.s) iz=1;
  if(G.keys.a) ix=-1; if(G.keys.d) ix=1;

  // Camera-relative vectors
  const fwd  = new THREE.Vector3(-Math.sin(G.camYaw),0,-Math.cos(G.camYaw));
  const right = new THREE.Vector3( Math.cos(G.camYaw),0,-Math.sin(G.camYaw));
  const vel   = new THREE.Vector3();
  vel.addScaledVector(fwd, iz*moveSpeed);
  vel.addScaledVector(right, ix*moveSpeed);

  // Direct velocity — guarantees translation
  const curY = pBody.velocity.y;
  pBody.velocity.set(vel.x, curY, vel.z);

  // Face movement direction
  const isMoving=vel.lengthSq()>.01;
  if(isMoving) pYaw=Math.atan2(vel.x,vel.z);

  // Clamp player strictly to ground (fix clipping)
  const minY = GROUND_Y + .5;
  if(pBody.position.y < minY) { pBody.position.y=minY; if(pBody.velocity.y<0)pBody.velocity.y=0; }

  // Sync mesh
  pMesh.position.set(pBody.position.x, pBody.position.y-.55, pBody.position.z);
  pMesh.rotation.y=pYaw;

  // Leg animation
  if(isMoving){
    legPhase+=dt*9;
    legL.rotation.x= Math.sin(legPhase)*.65;
    legR.rotation.x=-Math.sin(legPhase)*.65;
    footT-=dt;
    if(footT<=0){
      SFX.foot(Math.abs(pBody.position.x%80)<9||Math.abs(pBody.position.z%80)<9);
      footT=.35;
    }
  } else {
    legL.rotation.x*=.8; legR.rotation.x*=.8;
  }
}

// ── VEHICLE DRIVING (Proper Acceleration + Steering) ─────────
// FIX: real acceleration-based driving, not just force application
function updateVehicles(dt) {
  vehicles.forEach(v=>{
    const isOccupied = G.vehicle&&(v===vehicles[G.vehIdx]);
    if(!isOccupied){
      // Not driven — sync mesh to physics, apply idle gravity settle
      syncVehicleMesh(v);
      // Slowly bring to rest
      v.body.velocity.x*=.92; v.body.velocity.z*=.92;
      return;
    }
    if(!licenseOk){v.body.velocity.set(0,v.body.velocity.y,0);return;}

    let ix=G.joy.x, iy=-G.joy.y; // FIXED inversion
    if(G.keys.w) iy=-1; if(G.keys.s) iy=1;
    if(G.keys.a) ix=-1; if(G.keys.d) ix=1;

    // Acceleration
    const maxSpd = v.type==='bike'?22:15;
    const accel  = v.type==='bike'?18:12;
    const brake  = v.type==='bike'?.85:.82;
    v.speed -= iy * accel * dt;         // -iy because joy pushed up = forward
    v.speed  = Math.max(-maxSpd/2, Math.min(maxSpd, v.speed));
    v.speed *= (Math.abs(iy)<.05 ? brake : 1.0); // coast

    // Steering (only when moving)
    const steerRate = v.type==='bike'?.055:.04;
    if(Math.abs(v.speed)>.5) v.steer += ix * steerRate;
    v.steer *= .85; // auto-return to center

    // Rotate body yaw
    v.body.angularVelocity.y = -v.steer * Math.sign(v.speed) * 3.0;
    v.body.angularVelocity.x *= .4;
    v.body.angularVelocity.z *= .4;

    // Drive in heading direction
    const heading = 2*Math.atan2(v.body.quaternion.y, v.body.quaternion.w);
    v.body.velocity.x = -Math.sin(heading)*v.speed;
    v.body.velocity.z = -Math.cos(heading)*v.speed;
    v.body.velocity.y *= .97;

    // Clamp to ground
    const vMinY = GROUND_Y + (v.type==='bike'?BIKE_HALF_H:CAR_HALF_H) + .05;
    if(v.body.position.y < vMinY){ v.body.position.y=vMinY; if(v.body.velocity.y<0)v.body.velocity.y=0; }

    syncVehicleMesh(v);

    // Wheel spin
    v.wheelRot += v.speed*dt*3.5;
    v.wheels.forEach(w=>{ w.rotation.x=v.wheelRot; });
    if(v.type==='bike') v.group.rotation.z=-ix*.18*Math.min(Math.abs(v.speed)/8,1);

    document.getElementById('spd').textContent = Math.round(Math.abs(v.speed)*3.6);
    SFX.revEng(Math.min(Math.abs(v.speed)/maxSpd,1));

    // Suspension bounce
    v.group.position.y += Math.sin(Date.now()*.01)*.004*Math.abs(v.speed);

    // Sync player to vehicle
    pBody.position.set(v.body.position.x, v.body.position.y+1.4, v.body.position.z);
  });
}

function syncVehicleMesh(v) {
  v.group.position.copy(v.body.position);
  const offsetY = v.type==='bike'?-BIKE_HALF_H+.02:-CAR_HALF_H+.02;
  v.group.position.y = v.body.position.y+offsetY;
  v.group.quaternion.copy(v.body.quaternion);
}

// ── HELICOPTER ───────────────────────────────────────────────
let heliLifting=false, heliDown=false;
function updateHeli(dt) {
  if(G.vehicle!=='heli')return;
  if(!licenseOk){heliBody.velocity.set(0,0,0);return;}
  let ix=G.joy.x, iy=-G.joy.y;
  if(G.keys.a)ix=-1;if(G.keys.d)ix=1;if(G.keys.w)iy=-1;if(G.keys.s)iy=1;
  heliBody.applyForce(new CANNON.Vec3(0,(heliLifting?28000:(heliDown?-16000:0))+(22*1200*.92)*dt,0),heliBody.position);
  const hA=2*Math.atan2(heliBody.quaternion.y,heliBody.quaternion.w);
  heliBody.applyForce(new CANNON.Vec3(-Math.sin(hA)*iy*5000*dt+ix*5000*dt,0,-Math.cos(hA)*iy*5000*dt),heliBody.position);
  heliBody.angularVelocity.y+=ix*.04;heliBody.angularVelocity.y*=.9;
  heliBody.angularVelocity.x*=.6;heliBody.angularVelocity.z*=.6;
  heliG.rotation.z+=(-ix*.18-heliG.rotation.z)*.1;
  heliG.rotation.x+=(-iy*.15-heliG.rotation.x)*.1;
  heliG.position.copy(heliBody.position);heliG.position.y-=.65;
  heliG.quaternion.copy(heliBody.quaternion);
  rotorAngle+=dt*(heliLifting?25:15);
  rotorMesh.rotation.y=rotorAngle; tailRotor.rotation.x=rotorAngle*3;
  document.getElementById('alt-val').textContent=Math.round(Math.max(0,heliBody.position.y-2));
  SFX.revRot(Math.min(heliBody.velocity.length()/15,1));
  pBody.position.set(heliBody.position.x,heliBody.position.y+.8,heliBody.position.z);
}

