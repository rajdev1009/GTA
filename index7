// ── PROXIMITY ────────────────────────────────────────────────
function nearestVehicle() {
  const pp=new THREE.Vector3(pBody.position.x,pBody.position.y,pBody.position.z);
  let best=null,bestD=5.5,bestIdx=-1;
  vehicles.forEach((v,i)=>{
    const d=pp.distanceTo(new THREE.Vector3(v.body.position.x,v.body.position.y,v.body.position.z));
    if(d<bestD){bestD=d;best=v;bestIdx=i;}
  });
  if(heliBody){
    const dH=pp.distanceTo(new THREE.Vector3(heliBody.position.x,heliBody.position.y,heliBody.position.z));
    if(dH<5.5)return {v:null,idx:-1,type:'heli'};
  }
  return best?{v:best,idx:bestIdx,type:best.type}:null;
}

function nearestBuilding() {
  const pp=new THREE.Vector3(pBody.position.x,pBody.position.y,pBody.position.z);
  let best=null,bestD=8,bestIdx=-1;
  buildings.forEach((b,i)=>{const d=pp.distanceTo(b.pos);if(d<bestD){bestD=d;best=b;bestIdx=i;}});
  return best?{b:best,i:bestIdx}:null;
}

// ── CARJACKING ───────────────────────────────────────────────
// When player enters an occupied vehicle:
// 1. Flash "CARJACKING!" on screen
// 2. Eject NPC from driver seat mesh
// 3. Spawn the NPC in the world in angry state, chase player
function carjack(v, idx) {
  if(!v.occupied||!v.npc)return false;
  showCJFlash();
  SFX.scream();
  // Hide in-car NPC mesh
  if(v.npc.meshInCar) v.npc.meshInCar.visible=false;
  v.npc.ejected=true;

  // Spawn ejected NPC near car door in angry state
  const cx=v.body.position.x+3, cz=v.body.position.z;
  const name=NPC_NAMES[Math.floor(Math.random()*NPC_NAMES.length)];
  const npc=spawnNPC(cx,cz,name,v.npc.female,'angry');
  setNPCIcon(npc,'😡');
  npc.target=new THREE.Vector3(pBody.position.x,pBody.position.y,pBody.position.z);
  toast('🚨 CARJACKING! '+name+' is ANGRY and chasing you!', 3500);

  v.occupied=false; v.npc=null;
  return true;
}

// ── ENTER / EXIT ─────────────────────────────────────────────
function onEnterExit() {
  if(!G.alive||!licenseOk)return;

  if(G.vehicle==='heli'){
    G.vehicle=null;pMesh.visible=true;
    document.getElementById('alt-hud').classList.remove('show');
    SFX.stopRot();
    pBody.position.set(heliBody.position.x+3,heliBody.position.y,heliBody.position.z);
    pBody.velocity.set(0,0,0);flashZone('Open World');toast('Exited helicopter');return;
  }
  if(G.vehicle&&G.vehIdx>=0){
    const v=vehicles[G.vehIdx];
    G.vehicle=null;G.vehIdx=-1;pMesh.visible=true;
    document.getElementById('vhud').classList.remove('show');
    SFX.stopEng();v.speed=0;
    pBody.position.set(v.body.position.x+3,v.body.position.y,v.body.position.z);
    pBody.velocity.set(0,0,0);flashZone('Open World');toast('Exited '+v.type);return;
  }
  if(G.inside){
    const b=buildings[G.insideBldIdx];
    SFX.door();
    fadeIn(()=>{
      if(b){pBody.position.set(b.exitPos.x,b.exitPos.y,b.exitPos.z);pBody.velocity.set(0,0,0);b.group.visible=true;}
      G.inside=false;G.insideBldIdx=-1;flashZone('Open World');
    });return;
  }
  // Try building
  const nb=nearestBuilding();
  if(nb){
    SFX.door();
    const b=nb.b;
    if(!b.doorOpen){b.doorOpening=true;b.doorOpen=true;}
    fadeIn(()=>{
      pBody.position.set(b.pos.x,GROUND_Y+.55,b.pos.z);
      pBody.velocity.set(0,0,0);
      G.inside=true;G.insideBldIdx=nb.i;b.group.visible=false;
      flashZone('Inside: '+b.label);toast('ENTER to exit');
    });return;
  }
  // Try vehicles
  const nv=nearestVehicle();
  if(nv){
    if(nv.type==='heli'){
      G.vehicle='heli';pMesh.visible=false;
      document.getElementById('alt-hud').classList.add('show');
      SFX.startRot();flashZone('Helicopter');toast('UP=rise  DOWN=desc  Joystick=fly');return;
    }
    const v=nv.v;
    // CARJACKING check
    if(v.occupied){carjack(v,nv.idx);}
    G.vehicle=v.type;G.vehIdx=nv.idx;pMesh.visible=false;
    document.getElementById('vhud').classList.add('show');
    v.speed=0;
    SFX.startEng();flashZone(v.type==='car'?'Sports Car':'Motorcycle');
    toast('W/Joystick=drive  ENTER=exit');return;
  }
  toast('Nothing nearby to enter.');
}

