// ── 25. Action Handlers ─────────────────────────────────────
function onJump() {
  if(!State.engineEnabled||State.inVehicle) return;
  if(playerBody.position.y<2.8){ playerBody.velocity.y=9.5; SoundManager.playJump(); }
}
function onEnterExit() {
  if(!State.engineEnabled||transitioning) return;
  if(State.inVehicle){ exitVehicle(); return; }
  if(State.insideBuilding){ exitBuilding(); return; }
  if(nearBuilding){ enterBuilding(nearBuilding); return; }
  const pp=new THREE.Vector3(playerBody.position.x,playerBody.position.y,playerBody.position.z);
  const cp=new THREE.Vector3(carBody.position.x,carBody.position.y,carBody.position.z);
  if(pp.distanceTo(cp)<4.5) enterVehicle();
  else showToast('Nothing nearby to enter.');
}
function onAttack() {
  if(!State.engineEnabled||State.inVehicle) return;
  SoundManager.playHit(); damageNearestNPC();
}
function toggleHeadlights() {
  State.headlightsOn=!State.headlightsOn;
  carHeadlights.forEach(l=>l.intensity=State.headlightsOn?3.5:0);
  showToast(State.headlightsOn?'💡 Headlights ON':'💡 Headlights OFF');
}
window.onJump=onJump; window.onEnterExit=onEnterExit;
