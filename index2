// ── 20. Player Movement ─────────────────────────────────────
let footTimer=0;
function updatePlayer(dt) {
  if(!State.engineEnabled||State.inVehicle) return;
  let ix=State.joystick.x, iy=-State.joystick.y;
  if(State.keys.w) iy=-1; if(State.keys.s) iy=1;
  if(State.keys.a) ix=-1; if(State.keys.d) ix=1;
  playerYaw+=ix*1.9*dt;
  playerBody.applyForce(
    new CANNON.Vec3(Math.sin(playerYaw)*iy*300*dt, 0, Math.cos(playerYaw)*iy*300*dt),
    playerBody.position
  );
  playerBody.angularVelocity.set(0,0,0);
  playerMesh.position.set(playerBody.position.x,playerBody.position.y-.5,playerBody.position.z);
  playerMesh.rotation.y=-playerYaw;
  if(Math.abs(ix)>.05||Math.abs(iy)>.05){
    footTimer-=dt;
    if(footTimer<=0){ SoundManager.playFootstep(State.insideBuilding?'building':'grass'); footTimer=.38; }
  }
  checkNearBuilding();
}

// ── 21. Vehicle ─────────────────────────────────────────────
function updateVehicle(dt) {
  if(!State.engineEnabled||!State.inVehicle) return;
  let ix=State.joystick.x, iy=-State.joystick.y;
  if(State.keys.w) iy=-1; if(State.keys.s) iy=1;
  if(State.keys.a) ix=-1; if(State.keys.d) ix=1;
  const ang=Math.atan2(carBody.quaternion.x,carBody.quaternion.w)*2;
  carBody.applyForce(
    new CANNON.Vec3(-Math.sin(ang)*iy*6000*dt,0,-Math.cos(ang)*iy*6000*dt),
    carBody.position
  );
  carBody.angularVelocity.y+=ix*.06*(iy>=0?1:-1);
  carBody.angularVelocity.y*=.88;
  carBody.angularVelocity.x*=.4; carBody.angularVelocity.z*=.4;
  carBody.linearVelocity.y*=.96;
  carGroup.position.copy(carBody.position); carGroup.position.y-=.5;
  carGroup.quaternion.copy(carBody.quaternion);
  const spd=carBody.velocity.length();
  carWheelRot+=spd*dt*3.5;
  carWheels.forEach(w=>{ w.rotation.x=carWheelRot; });
  document.getElementById('speed-display').textContent=Math.round(spd*3.6);
  SoundManager.revEngine(Math.min(spd/18,1));
  carGroup.position.y+=Math.sin(Date.now()*.009)*.007*spd;
  playerBody.position.set(carBody.position.x,carBody.position.y+1.2,carBody.position.z);
}

