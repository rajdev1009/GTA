<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>AstraToonix Open World</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cannon.js/0.6.2/cannon.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html,body{width:100%;height:100%;overflow:hidden;background:#0a0a12;font-family:'Rajdhani',sans-serif;touch-action:none;user-select:none;-webkit-user-select:none}

    /* PORTRAIT OVERLAY — z-index 8000, below loading (10000), has dismiss button */
    #portrait-overlay{display:none;position:fixed;inset:0;z-index:8000;background:linear-gradient(135deg,#0d0d1f,#1a0a2e);flex-direction:column;align-items:center;justify-content:center;gap:18px}
    #portrait-overlay.visible{display:flex}
    .rotate-icon{font-size:64px;animation:rotAnim 1.8s ease-in-out infinite}
    @keyframes rotAnim{0%,100%{transform:rotate(0)}40%,60%{transform:rotate(90deg)}}
    #portrait-overlay h2{font-family:'Orbitron',monospace;color:#7efff5;font-size:clamp(.9rem,5vw,1.3rem);text-align:center;letter-spacing:2px;text-shadow:0 0 20px #7efff580}
    #portrait-overlay p{color:#8899bb;font-size:.85rem;letter-spacing:1px}
    #portrait-play-btn{margin-top:6px;background:rgba(126,255,245,.12);border:2px solid #7efff5;color:#7efff5;font-family:'Orbitron',monospace;font-size:.65rem;letter-spacing:2px;padding:10px 24px;border-radius:6px;cursor:pointer;-webkit-tap-highlight-color:transparent}

    /* CANVAS */
    #game-canvas{position:fixed;top:0;left:0;display:block;width:100%!important;height:100%!important}

    /* HUD */
    #hud{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:linear-gradient(180deg,rgba(0,0,0,.65) 0%,transparent 100%);pointer-events:none}
    #hud-left{display:flex;flex-direction:column;gap:3px}
    .hud-label{font-family:'Orbitron',monospace;font-size:.55rem;color:#7efff5;letter-spacing:2px}
    .health-bar-wrap{width:110px;height:8px;background:rgba(255,255,255,.1);border-radius:4px;overflow:hidden}
    #player-health-bar{height:100%;width:100%;background:linear-gradient(90deg,#00ff88,#7efff5);border-radius:4px;transition:width .3s ease}
    #hud-center{font-family:'Orbitron',monospace;font-size:clamp(.5rem,2.5vw,.72rem);color:#fff;letter-spacing:3px;text-shadow:0 0 12px #7efff5}
    #hud-right{font-family:'Orbitron',monospace;font-size:.52rem;color:#ffcc44;letter-spacing:1px;text-align:right}

    /* DEV CREDIT — IDENTITY PROTECTION ANCHOR — DO NOT ALTER */
    #dev-credit{position:fixed;bottom:5px;left:50%;transform:translateX(-50%);z-index:200;font-family:'Orbitron',monospace;font-size:.42rem;color:rgba(126,255,245,.3);letter-spacing:2px;pointer-events:none}

    /* ZONE NOTICE */
    #zone-notice{position:fixed;top:52px;left:50%;transform:translateX(-50%);z-index:110;font-family:'Orbitron',monospace;font-size:clamp(.65rem,3vw,.95rem);color:#fff;letter-spacing:3px;text-shadow:0 0 18px #7efff5;opacity:0;transition:opacity .5s;pointer-events:none;white-space:nowrap}
    #zone-notice.show{opacity:1}

    /* ENGINE DISABLED */
    #engine-disabled-overlay{display:none;position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,.93);flex-direction:column;align-items:center;justify-content:center;gap:14px}
    #engine-disabled-overlay.visible{display:flex}
    #engine-disabled-overlay h2{font-family:'Orbitron',monospace;color:#ff4455;font-size:1.1rem;letter-spacing:3px;text-shadow:0 0 20px #ff4455}
    #engine-disabled-overlay p{color:#8899bb;font-size:.78rem;letter-spacing:1px}

    /* TRANSITION */
    #transition-overlay{position:fixed;inset:0;z-index:500;background:#000;opacity:0;pointer-events:none;transition:opacity .4s ease}
    #transition-overlay.fade{opacity:1;pointer-events:all}

    /* TOAST */
    #toast{position:fixed;top:64px;left:50%;transform:translateX(-50%);z-index:300;background:rgba(0,0,0,.82);border:1px solid #7efff540;border-radius:8px;padding:7px 16px;font-family:'Rajdhani',sans-serif;font-size:.82rem;color:#7efff5;letter-spacing:1px;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(8px);white-space:nowrap}
    #toast.show{opacity:1}

    /* VEHICLE HUD */
    #vehicle-hud{position:fixed;bottom:130px;right:14px;z-index:110;display:none;flex-direction:column;align-items:flex-end;gap:4px}
    #vehicle-hud.visible{display:flex}
    #speed-display{font-family:'Orbitron',monospace;font-size:clamp(1.2rem,6vw,1.8rem);color:#ffcc44;text-shadow:0 0 12px #ffcc4480}
    #speed-unit{font-family:'Rajdhani',sans-serif;font-size:.62rem;color:#8899bb;letter-spacing:2px}
    #headlight-btn{background:rgba(0,0,0,.6);border:1px solid #ffcc44;color:#ffcc44;font-family:'Orbitron',monospace;font-size:.48rem;letter-spacing:1px;padding:5px 10px;border-radius:4px;cursor:pointer;pointer-events:all;-webkit-tap-highlight-color:transparent}

    /* JOYSTICK */
    #joystick-zone{position:fixed;bottom:18px;left:18px;width:110px;height:110px;z-index:150;pointer-events:all}
    #joystick-base{width:110px;height:110px;border-radius:50%;background:rgba(126,255,245,.07);border:2px solid rgba(126,255,245,.22);position:relative}
    #joystick-thumb{width:44px;height:44px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#7efff5,#1a8888);border:2px solid rgba(255,255,255,.25);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);box-shadow:0 0 14px #7efff540}

    /* ACTION BUTTONS */
    #action-zone{position:fixed;bottom:18px;right:14px;z-index:150;pointer-events:all;display:flex;flex-direction:column;align-items:flex-end;gap:8px}
    .action-row{display:flex;gap:8px}
    .action-btn{width:46px;height:46px;border-radius:50%;border:2px solid rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:.48rem;color:#fff;cursor:pointer;backdrop-filter:blur(6px);letter-spacing:.5px;transition:transform .1s;-webkit-tap-highlight-color:transparent}
    .action-btn:active{transform:scale(.88)}
    #btn-jump{background:rgba(126,255,245,.15);border-color:#7efff5}
    #btn-enter{background:rgba(255,204,68,.15);border-color:#ffcc44}
    #btn-attack{background:rgba(255,68,85,.15);border-color:#ff4455}
    #btn-car{background:rgba(100,200,255,.15);border-color:#64c8ff}

    /* NPC HUD */
    .npc-hud{position:fixed;z-index:120;pointer-events:none;display:flex;flex-direction:column;align-items:center;gap:2px}
    .npc-name{font-family:'Rajdhani',sans-serif;font-size:.58rem;color:#fff;letter-spacing:1px;text-shadow:0 1px 3px #000}
    .npc-bar-outer{width:52px;height:5px;background:rgba(0,0,0,.5);border-radius:3px;overflow:hidden;border:1px solid rgba(255,255,255,.18)}
    .npc-bar-inner{height:100%;background:#ff4455;border-radius:3px;transition:width .3s}
    .npc-fear-icon{font-size:.72rem;animation:fearPulse .5s ease infinite alternate}
    @keyframes fearPulse{from{transform:scale(1)}to{transform:scale(1.3)}}

    /* LOADING */
    #loading-screen{position:fixed;inset:0;z-index:10000;background:#06060f;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity .6s ease}
    #loading-screen.fade-out{opacity:0;pointer-events:none}
    #loading-screen h1{font-family:'Orbitron',monospace;font-size:clamp(1.3rem,7vw,2.2rem);color:#7efff5;letter-spacing:5px;text-shadow:0 0 40px #7efff5;animation:glowPulse 2s ease infinite;text-align:center}
    @keyframes glowPulse{0%,100%{text-shadow:0 0 40px #7efff5}50%{text-shadow:0 0 80px #7efff5,0 0 120px #7efff580}}
    #loading-sub{font-family:'Orbitron',monospace;font-size:.6rem;color:#4488aa;letter-spacing:3px}
    #loading-bar-outer{width:min(260px,70vw);height:4px;background:rgba(255,255,255,.1);border-radius:2px;overflow:hidden}
    #loading-bar-inner{height:100%;width:0%;background:linear-gradient(90deg,#7efff5,#64c8ff);border-radius:2px;transition:width .35s ease}
    #loading-tip{font-family:'Rajdhani',sans-serif;font-size:.78rem;color:#556677;letter-spacing:2px}

    /* MINI MAP */
    #minimap{position:fixed;top:48px;right:12px;z-index:110;width:80px;height:80px;border-radius:50%;overflow:hidden;pointer-events:none;border:1px solid rgba(126,255,245,.22)}
    #minimap-canvas{width:80px;height:80px}
  </style>
</head>
<body>

  <!-- PORTRAIT OVERLAY: has "Play Anyway" so users are never fully blocked -->
  <div id="portrait-overlay">
    <div class="rotate-icon">📱</div>
    <h2>AstraToonix<br/>Rotate Your Phone</h2>
    <p>Best in Landscape mode</p>
    <button id="portrait-play-btn">▶ PLAY ANYWAY</button>
  </div>

  <!-- ENGINE DISABLED: only shows if Raj Dev credit is tampered -->
  <div id="engine-disabled-overlay">
    <h2>⛔ ENGINE DISABLED</h2>
    <p>Developer credit integrity check failed.</p>
    <p style="color:#ff4455;font-size:.62rem;letter-spacing:1px;margin-top:6px">Required: Raj Dev | AstraToonix Engine</p>
  </div>

  <!-- LOADING SCREEN -->
  <div id="loading-screen">
    <h1>ASTRATOONIX</h1>
    <div id="loading-sub">OPEN WORLD ENGINE</div>
    <div id="loading-bar-outer"><div id="loading-bar-inner"></div></div>
    <div id="loading-tip">Initializing…</div>
  </div>

  <canvas id="game-canvas"></canvas>

  <!-- HUD -->
  <div id="hud">
    <div id="hud-left">
      <div class="hud-label">HEALTH</div>
      <div class="health-bar-wrap"><div id="player-health-bar"></div></div>
    </div>
    <div id="hud-center">ASTRATOONIX</div>
    <div id="hud-right">OPEN WORLD</div>
  </div>

  <div id="zone-notice"></div>
  <div id="toast"></div>
  <div id="transition-overlay"></div>

  <!-- VEHICLE HUD -->
  <div id="vehicle-hud">
    <div id="speed-display">0</div>
    <div id="speed-unit">KM/H</div>
    <button id="headlight-btn">💡 LIGHTS</button>
  </div>

  <!-- MINI MAP -->
  <div id="minimap"><canvas id="minimap-canvas" width="80" height="80"></canvas></div>

  <!-- TOUCH JOYSTICK -->
  <div id="joystick-zone"><div id="joystick-base"><div id="joystick-thumb"></div></div></div>

  <!-- ACTION BUTTONS -->
  <div id="action-zone">
    <div class="action-row">
      <div class="action-btn" id="btn-jump">JUMP</div>
      <div class="action-btn" id="btn-enter">ENTER</div>
    </div>
    <div class="action-row">
      <div class="action-btn" id="btn-attack">HIT</div>
      <div class="action-btn" id="btn-car">CAR</div>
    </div>
  </div>

  <!--
    ================================================================
    DEVELOPER CREDIT — IDENTITY PROTECTION ANCHOR
    *** ENGINE READS THIS AT STARTUP — DO NOT REMOVE OR EDIT ***
    *** Raj Dev — AstraToonix Engine Author                  ***
    ================================================================
  -->
  <div id="dev-credit">Raj Dev</div>

<script>
'use strict';
/* ================================================================
   ASTRATOONIX OPEN WORLD ENGINE  v1.1
   Author  : Raj Dev
   Identity Protection: #dev-credit must contain exactly 'Raj Dev'
================================================================ */

// ── 1. Portrait Overlay (non-blocking — has dismiss button) ──
let portraitDismissed = false;

document.getElementById('portrait-play-btn').addEventListener('click', () => {
  portraitDismissed = true;
  document.getElementById('portrait-overlay').classList.remove('visible');
});
document.getElementById('portrait-play-btn').addEventListener('touchend', e => {
  e.preventDefault();
  portraitDismissed = true;
  document.getElementById('portrait-overlay').classList.remove('visible');
});

function checkOrientation() {
  if (portraitDismissed) return;
  const ov = document.getElementById('portrait-overlay');
  // Only show overlay if truly portrait — give 50px buffer for mobile browser chrome
  if (window.innerHeight > window.innerWidth + 50) {
    ov.classList.add('visible');
  } else {
    ov.classList.remove('visible');
  }
}
window.addEventListener('resize', checkOrientation);
window.addEventListener('orientationchange', () => setTimeout(checkOrientation, 300));
// Delay first orientation check — let loading screen show first
setTimeout(checkOrientation, 1000);

// ── 2. Identity Protection ──────────────────────────────────
// *** CORE ENGINE GATE: character + vehicle + NPC systems are
//     disabled if #dev-credit does not contain 'Raj Dev' ***
function checkDevCredit() {
  const el = document.getElementById('dev-credit');
  if (!el || el.textContent.trim() !== 'Raj Dev') {
    document.getElementById('engine-disabled-overlay').classList.add('visible');
    return false; // HALT ENGINE
  }
  return true;
}

// ── 3. Loading helpers ──────────────────────────────────────
function setLoad(pct, tip) {
  document.getElementById('loading-bar-inner').style.width = pct + '%';
  if (tip) document.getElementById('loading-tip').textContent = tip;
}
function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// ── 4. Sound Manager (Web Audio API placeholder) ────────────
const SoundManager = (() => {
  let ctx=null, eGain=null, eOsc=null, eRunning=false;
  function getCtx() {
    if (!ctx) ctx = new (window.AudioContext||window.webkitAudioContext)();
    if (ctx.state==='suspended') ctx.resume().catch(()=>{});
    return ctx;
  }
  function beep(freq, dur, type='sine', vol=0.1) {
    try {
      const c=getCtx(), o=c.createOscillator(), g=c.createGain();
      o.type=type; o.frequency.setValueAtTime(freq, c.currentTime);
      g.gain.setValueAtTime(vol, c.currentTime);
      g.gain.exponentialRampToValueAtTime(0.0001, c.currentTime+dur);
      o.connect(g); g.connect(c.destination); o.start(); o.stop(c.currentTime+dur);
    } catch(e) {}
  }
  return {
    playFootstep(s) {
      if (s==='grass')    beep(155+Math.random()*40, 0.08,'triangle', 0.04);
      if (s==='building') beep(330+Math.random()*60, 0.05,'square',   0.035);
    },
    startEngine() {
      if (eRunning) return;
      try {
        const c=getCtx(); eOsc=c.createOscillator(); eGain=c.createGain();
        eOsc.type='sawtooth'; eOsc.frequency.setValueAtTime(55, c.currentTime);
        eGain.gain.setValueAtTime(0.06, c.currentTime);
        eOsc.connect(eGain); eGain.connect(c.destination); eOsc.start(); eRunning=true;
      } catch(e) {}
    },
    stopEngine() {
      if (!eRunning) return;
      try {
        eGain.gain.exponentialRampToValueAtTime(0.0001, getCtx().currentTime+0.4);
        eOsc.stop(getCtx().currentTime+0.5);
      } catch(e) {}
      eRunning=false; eOsc=null; eGain=null;
    },
    revEngine(t) {
      if (!eOsc||!eRunning) return;
      try { eOsc.frequency.setValueAtTime(55+t*200, getCtx().currentTime); } catch(e) {}
    },
    playScream() { beep(860,0.22,'sawtooth',0.09); setTimeout(()=>beep(640,0.18,'sawtooth',0.06),110); },
    playDoor()   { beep(200,0.12,'triangle',0.07); },
    playJump()   { beep(270,0.1,'sine',0.06); },
    playHit()    { beep(95,0.08,'square',0.1); },
    playHorn()   { beep(440,0.3,'square',0.15); }
  };
})();

// ── 5. UI Helpers ───────────────────────────────────────────
let toastTimer=null;
function showToast(msg, dur=2600) {
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'), dur);
}
let zoneTimer=null;
function showZone(name) {
  const z=document.getElementById('zone-notice');
  z.textContent=name; z.classList.add('show');
  clearTimeout(zoneTimer);
  zoneTimer=setTimeout(()=>z.classList.remove('show'), 3200);
  document.getElementById('hud-right').textContent=name;
}

// ── 6. Game State ───────────────────────────────────────────
const State = {
  engineEnabled:false, inVehicle:false, insideBuilding:false,
  playerHealth:100, headlightsOn:false,
  keys:{ w:false,a:false,s:false,d:false },
  joystick:{ x:0, y:0 }
};

// ── 7. Three.js ─────────────────────────────────────────────
const canvas = document.getElementById('game-canvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias:false, powerPreference:'high-performance' });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
renderer.shadowMap.enabled=true;
renderer.shadowMap.type=THREE.PCFSoftShadowMap;
renderer.setClearColor(0x87ceeb);

const scene  = new THREE.Scene();
scene.fog    = new THREE.Fog(0x87ceeb, 55, 180);

const camera = new THREE.PerspectiveCamera(65, window.innerWidth/window.innerHeight, 0.1, 400);
camera.position.set(0, 5, 10);

function onResize() {
  renderer.setSize(window.innerWidth, window.innerHeight, false);
  camera.aspect = window.innerWidth/window.innerHeight;
  camera.updateProjectionMatrix();
}
window.addEventListener('resize', onResize);
onResize();

// ── 8. Cannon.js Physics ────────────────────────────────────
const world = new CANNON.World();
world.gravity.set(0,-22,0);
world.broadphase = new CANNON.SAPBroadphase(world);
world.solver.iterations=10;

// ── 9. Lighting ─────────────────────────────────────────────
scene.add(new THREE.AmbientLight(0xffffff, 0.55));
const sun = new THREE.DirectionalLight(0xfff8e7, 1.1);
sun.position.set(60,90,40); sun.castShadow=true;
sun.shadow.mapSize.set(1024,1024);
sun.shadow.camera.near=1; sun.shadow.camera.far=250;
sun.shadow.camera.left=-70; sun.shadow.camera.right=70;
sun.shadow.camera.bottom=-70; sun.shadow.camera.top=70;
scene.add(sun);

// ── 10. Sky ─────────────────────────────────────────────────
const skyGeo = new THREE.SphereGeometry(380,16,16);
skyGeo.scale(-1,1,1);
const skyC=[], skyP=skyGeo.attributes.position;
for(let i=0;i<skyP.count;i++){
  const t=(skyP.getY(i)/380+1)/2;
  skyC.push(0.52-t*0.28, 0.78-t*0.32, 0.92-t*0.25);
}
skyGeo.setAttribute('color',new THREE.Float32BufferAttribute(skyC,3));
scene.add(new THREE.Mesh(skyGeo,new THREE.MeshBasicMaterial({vertexColors:true,side:THREE.BackSide})));

// ── 11. Materials ───────────────────────────────────────────
const M = {
  ground  :new THREE.MeshLambertMaterial({color:0x4a9c3f}),
  road    :new THREE.MeshLambertMaterial({color:0x3d3d50}),
  sidewalk:new THREE.MeshLambertMaterial({color:0x9999aa}),
  door    :new THREE.MeshLambertMaterial({color:0x5c3a1e}),
  window  :new THREE.MeshLambertMaterial({color:0x88ddff,transparent:true,opacity:0.55}),
  carRed  :new THREE.MeshLambertMaterial({color:0xee2222}),
  carDark :new THREE.MeshLambertMaterial({color:0xcc3333}),
  wheel   :new THREE.MeshLambertMaterial({color:0x1a1a2e}),
  player  :new THREE.MeshLambertMaterial({color:0x3366cc}),
  skin    :new THREE.MeshLambertMaterial({color:0xffd27f}),
  interior:new THREE.MeshLambertMaterial({color:0xd4b896}),
  trunk   :new THREE.MeshLambertMaterial({color:0x5c3a1e}),
  leaves  :new THREE.MeshLambertMaterial({color:0x2d6a27}),
  lamp    :new THREE.MeshBasicMaterial({color:0xffffcc}),
  npc     :new THREE.MeshLambertMaterial({color:0xffd27f})
};

// ── 12. Ground & Roads ──────────────────────────────────────
function buildGround() {
  const m=new THREE.Mesh(new THREE.PlaneGeometry(300,300),M.ground);
  m.rotation.x=-Math.PI/2; m.receiveShadow=true; scene.add(m);
  const b=new CANNON.Body({mass:0});
  b.addShape(new CANNON.Plane());
  b.quaternion.setFromAxisAngle(new CANNON.Vec3(1,0,0),-Math.PI/2);
  world.addBody(b);
}
function buildRoads() {
  [[300,9],[9,300]].forEach(([w,d],i)=>{
    const m=new THREE.Mesh(new THREE.PlaneGeometry(w,d),M.road);
    m.rotation.x=-Math.PI/2; m.position.y=0.015; scene.add(m);
  });
  [[-7,0,300,2],[7,0,300,2],[0,-7,2,300],[0,7,2,300]].forEach(([x,z,w,d])=>{
    const m=new THREE.Mesh(new THREE.PlaneGeometry(w,d),M.sidewalk);
    m.rotation.x=-Math.PI/2; m.position.set(x,0.02,z); scene.add(m);
  });
}

// ── 13. Buildings ───────────────────────────────────────────
const buildings=[];
function buildHouse(x,z,label,color=0xc8aa80) {
  const mat=new THREE.MeshLambertMaterial({color});
  const g=new THREE.Group();
  // Walls
  const walls=new THREE.Mesh(new THREE.BoxGeometry(8,5,8),mat);
  walls.position.y=2.5; walls.castShadow=true; walls.receiveShadow=true; g.add(walls);
  // Roof
  const roof=new THREE.Mesh(new THREE.ConeGeometry(6.5,3,4),new THREE.MeshLambertMaterial({color:0x8b3a3a}));
  roof.position.y=6.5; roof.rotation.y=Math.PI/4; g.add(roof);
  // Windows
  [[-2,3,4.01],[2,3,4.01]].forEach(([wx,wy,wz])=>{
    const w=new THREE.Mesh(new THREE.PlaneGeometry(1.4,1.3),M.window);
    w.position.set(wx,wy,wz); g.add(w);
  });
  // Door frame
  const df=new THREE.Mesh(new THREE.BoxGeometry(2.2,3.2,.12),M.door);
  df.position.set(0,1.6,4.02); g.add(df);
  // Door pivot
  const pivot=new THREE.Group();
  pivot.position.set(-0.95,0,4.02);
  const dm=new THREE.Mesh(new THREE.BoxGeometry(1.8,2.9,.08),M.door);
  dm.position.set(0.9,1.45,0); pivot.add(dm); g.add(pivot);
  // Step
  const step=new THREE.Mesh(new THREE.BoxGeometry(2.5,.15,.6),M.sidewalk);
  step.position.set(0,.08,4.35); g.add(step);
  g.position.set(x,0,z); scene.add(g);
  // Physics
  const b=new CANNON.Body({mass:0});
  b.addShape(new CANNON.Box(new CANNON.Vec3(4,2.5,4)));
