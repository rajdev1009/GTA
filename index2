// ── 23. Building Entry / Exit ───────────────────────────────
let nearBuilding=null, transitioning=false;
function checkNearBuilding() {
  const pp=new THREE.Vector3(playerBody.position.x,playerBody.position.y,playerBody.position.z);
  nearBuilding=null;
  buildings.forEach(b=>{ if(pp.distanceTo(b.worldPos)<7) nearBuilding=b; });
}
function enterBuilding(b) {
  transitioning=true; SoundManager.playDoor(); b.doorOpening=true;
  const ov=document.getElementById('transition-overlay');
  ov.classList.add('fade');
  setTimeout(()=>{
    playerBody.position.set(b.worldPos.x,1,b.worldPos.z-1.5);
    playerBody.velocity.set(0,0,0);
    State.insideBuilding=true; b.interior.visible=true; b.group.visible=false;
    showZone('Inside: '+b.label); showToast('Press ENTER to exit');
    ov.classList.remove('fade'); transitioning=false;
  },430);
}
function exitBuilding() {
  transitioning=true; SoundManager.playDoor();
  const ov=document.getElementById('transition-overlay');
  ov.classList.add('fade');
  setTimeout(()=>{
    const b=buildings.find(bld=>bld.interior.visible);
    if(b){
      playerBody.position.set(b.exitPoint.x,1,b.exitPoint.z);
      playerBody.velocity.set(0,0,0);
      b.interior.visible=false; b.group.visible=true;
      b.doorOpening=false; b.doorAngle=0; b.doorPivot.rotation.y=0;
    }
    State.insideBuilding=false; showZone('Open World');
    ov.classList.remove('fade'); transitioning=false;
  },430);
}

// ── 24. Car Enter / Exit ────────────────────────────────────
function enterVehicle() {
  State.inVehicle=true; playerMesh.visible=false;
  document.getElementById('vehicle-hud').classList.add('visible');
