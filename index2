// ── 28. Mini-map ─────────────────────────────────────────────
const mmCtx=document.getElementById('minimap-canvas').getContext('2d');
const MMS=80/200;
function drawMinimap() {
  mmCtx.clearRect(0,0,80,80);
  mmCtx.fillStyle='rgba(15,20,35,.75)';
  mmCtx.beginPath();mmCtx.arc(40,40,40,0,Math.PI*2);mmCtx.fill();
  mmCtx.strokeStyle='#444455';mmCtx.lineWidth=2.5;
  mmCtx.beginPath();mmCtx.moveTo(40,0);mmCtx.lineTo(40,80);mmCtx.stroke();
  mmCtx.beginPath();mmCtx.moveTo(0,40);mmCtx.lineTo(80,40);mmCtx.stroke();
  mmCtx.fillStyle='#88aaff';
  buildings.forEach(b=>{
    const mx=40+b.worldPos.x*MMS, mz=40+b.worldPos.z*MMS;
    mmCtx.fillRect(mx-2.5,mz-2.5,5,5);
  });
  mmCtx.fillStyle='#ffcc44';
  npcs.forEach(n=>{
    if(n.dead) return;
    mmCtx.beginPath();mmCtx.arc(40+n.group.position.x*MMS,40+n.group.position.z*MMS,1.5,0,Math.PI*2);mmCtx.fill();
  });
  if(carBody){
    mmCtx.fillStyle='#ff4444';
    mmCtx.beginPath();mmCtx.arc(40+carBody.position.x*MMS,40+carBody.position.z*MMS,2.5,0,Math.PI*2);mmCtx.fill();
  }
  if(playerBody){
    const px=40+playerBody.position.x*MMS, pz=40+playerBody.position.z*MMS;
    mmCtx.fillStyle='#ffffff';
    mmCtx.beginPath();mmCtx.arc(px,pz,3,0,Math.PI*2);mmCtx.fill();
    mmCtx.strokeStyle='#7efff5';mmCtx.lineWidth=1.5;
    mmCtx.beginPath();mmCtx.moveTo(px,pz);
    mmCtx.lineTo(px-Math.sin(playerYaw)*7,pz-Math.cos(playerYaw)*7);
    mmCtx.stroke();
  }
  mmCtx.globalCompositeOperation='destination-in';
  mmCtx.beginPath();mmCtx.arc(40,40,40,0,Math.PI*2);mmCtx.fill();
  mmCtx.globalCompositeOperation='source-over';
}

// ── 29. Main Loop ────────────────────────────────────────────
const FIXED=1/60; let lastT=null;
function gameLoop(t) {
  requestAnimationFrame(gameLoop);
  const dt=lastT===null?FIXED:Math.min((t-lastT)/1000,.05);
  lastT=t;
  if(!State.engineEnabled){renderer.render(scene,camera);return;}
  world.step(FIXED,dt,3);
  updatePlayer(dt); updateVehicle(dt); updateDoors(dt);
  updateNPCs(dt); updateNPCHUDs(); updateCamera();
  document.getElementById('player-health-bar').style.width=State.playerHealth+'%';
  drawMinimap();
  renderer.render(scene,camera);
}

// ── 30. INIT ─────────────────────────────────────────────────
async function init() {
  setLoad(10,'Verifying developer credit…');
  await sleep(120);

  // *** IDENTITY PROTECTION: Raj Dev credit check ***
  // Engine halts completely if #dev-credit != 'Raj Dev'
  if(!checkDevCredit()){
    setLoad(100,'Engine disabled — credit check failed.');
    setTimeout(()=>{ document.getElementById('loading-screen').style.display='none'; },1200);
    return;
  }

  setLoad(25,'Building terrain…');
  await sleep(180);
  buildWorld();

  setLoad(58,'Initializing physics…');
  await sleep(200);

  setLoad(78,'Spawning NPCs…');
  await sleep(150);

  setLoad(94,'Starting renderer…');
  await sleep(150);

  // *** ENGINE ARMED — Raj Dev verified ***
  State.engineEnabled=true;

  setLoad(100,'Welcome to AstraToonix!');
  await sleep(350);

  const ls=document.getElementById('loading-screen');
  ls.classList.add('fade-out');
  setTimeout(()=>{ ls.style.display='none'; },700);

  showZone('Open World');
  setTimeout(()=>showToast('Joystick=move • ENTER=building • CAR=drive • HIT=attack'),900);

  requestAnimationFrame(gameLoop);
}

init();
</script>
