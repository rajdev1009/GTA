function damageNearestNPC() {
  const pp=new THREE.Vector3(playerBody.position.x,playerBody.position.y,playerBody.position.z);
  let nearest=null, minD=4.5;
  npcs.forEach(n=>{
    if(n.dead) return;
    const d=n.group.position.distanceTo(pp);
    if(d<minD){minD=d;nearest=n;}
  });
  if(!nearest){showToast('No one nearby!');return;}
  nearest.health-=25;
  nearest.fear=true; nearest.fearTimer=6;
  nearest.fleeDir.set(nearest.group.position.x-pp.x,0,nearest.group.position.z-pp.z).normalize();
  SoundManager.playScream(); SoundManager.playHit();
  nearest.barEl.style.width=Math.max(0,nearest.health)+'%';
  if(nearest.health<=0){
    nearest.dead=true; nearest.group.visible=false; nearest.hudEl.style.display='none';
    showToast(nearest.name+' is down!');
  } else {
    if(!nearest.hudEl.querySelector('.npc-fear-icon')){
      const fi=document.createElement('div'); fi.className='npc-fear-icon'; fi.textContent='😱';
      nearest.hudEl.prepend(fi);
    }
    showToast(nearest.name+': '+nearest.health+'HP — FLEEING!');
  }
}

const projV=new THREE.Vector3();
function updateNPCHUDs() {
  npcs.forEach(n=>{
    if(n.dead) return;
    projV.set(n.group.position.x,n.group.position.y+1.6,n.group.position.z);
    projV.project(camera);
    const sx=(projV.x+1)*window.innerWidth*.5;
    const sy=(-projV.y+1)*window.innerHeight*.5;
    if(projV.z<1&&sx>0&&sx<window.innerWidth&&sy>0&&sy<window.innerHeight){
      n.hudEl.style.cssText=`display:flex;left:${sx}px;top:${sy}px;transform:translate(-50%,-100%)`;
    } else { n.hudEl.style.display='none'; }
  });
}

function updateNPCs(dt) {
  npcs.forEach(n=>{
    if(n.dead) return;
    if(n.fear){
      n.fearTimer-=dt;
      if(n.fearTimer<=0){n.fear=false;const fi=n.hudEl.querySelector('.npc-fear-icon');if(fi)fi.remove();}
      n.group.position.x+=n.fleeDir.x*5*dt;
      n.group.position.z+=n.fleeDir.z*5*dt;
    } else {
      n.idleTimer-=dt;
      if(n.idleTimer<=0){
        n.walkDir.set(Math.random()*2-1,0,Math.random()*2-1).normalize();
        n.idleTimer=2+Math.random()*3;
      }
      n.group.position.x+=n.walkDir.x*1.3*dt;
      n.group.position.z+=n.walkDir.z*1.3*dt;
      n.group.rotation.y=Math.atan2(n.walkDir.x,n.walkDir.z);
    }
    n.group.position.x=Math.max(-90,Math.min(90,n.group.position.x));
    n.group.position.z=Math.max(-90,Math.min(90,n.group.position.z));
  });
}

