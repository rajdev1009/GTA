// ── 27. Touch Joystick ───────────────────────────────────────
const jBase=document.getElementById('joystick-base');
const jThumb=document.getElementById('joystick-thumb');
let jTouchId=null;
const JR=34;
jBase.addEventListener('touchstart',e=>{ e.preventDefault(); jTouchId=e.changedTouches[0].identifier; },{passive:false});
document.addEventListener('touchmove',e=>{
  if(jTouchId===null) return;
  const t=[...e.changedTouches].find(t=>t.identifier===jTouchId);
  if(!t) return;
  e.preventDefault();
  const r=jBase.getBoundingClientRect();
  let dx=t.clientX-(r.left+r.width/2), dy=t.clientY-(r.top+r.height/2);
  const dist=Math.sqrt(dx*dx+dy*dy);
  if(dist>JR){dx=dx/dist*JR;dy=dy/dist*JR;}
  jThumb.style.transform=`translate(calc(-50% + ${dx}px),calc(-50% + ${dy}px))`;
  State.joystick.x=dx/JR; State.joystick.y=dy/JR;
},{passive:false});
function resetJoy(){
  jThumb.style.transform='translate(-50%,-50%)';
  State.joystick.x=State.joystick.y=0; jTouchId=null;
}
document.addEventListener('touchend',e=>{
  if([...e.changedTouches].find(t=>t.identifier===jTouchId)) resetJoy();
});

// Attach button events properly (touchstart + click for desktop)
function addBtn(id,fn){
  const el=document.getElementById(id);
  el.addEventListener('touchstart',e=>{e.preventDefault();fn();},{passive:false});
  el.addEventListener('click',fn);
}
