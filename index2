  document.body.appendChild(hudEl);
  npcs.push({
    group:g, hudEl, barEl:hudEl.querySelector('.npc-bar-inner'),
    name, health:100, fear:false, fearTimer:0, dead:false,
    idleTimer:Math.random()*3,
    walkDir:new THREE.Vector3(Math.random()*2-1,0,Math.random()*2-1).normalize(),
    fleeDir:new THREE.Vector3(Math.random()*2-1,0,Math.random()*2-1).normalize()
  });
